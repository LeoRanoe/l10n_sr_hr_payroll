<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_payslip_run_form_sr_tax_overview" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.sr.tax.overview</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="sr_has_sr_payslips" invisible="1"/>
                <button
                    name="action_print_sr_tax_overview"
                    string="PDF Belastingoverzicht"
                    type="object"
                    class="btn-secondary"
                    icon="fa-file-pdf-o"
                    invisible="state not in ('close', 'paid') or not sr_has_sr_payslips"
                    help="Exporteer per loonrun een belastingoverzicht in PDF voor alle afgeronde SR-loonstroken."/>
            </xpath>
        </field>
    </record>

</odoo>