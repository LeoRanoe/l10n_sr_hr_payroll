<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── List view ──────────────────────────────────────────────────── -->
    <record id="sr_public_holiday_view_list" model="ir.ui.view">
        <field name="name">sr.public.holiday.list</field>
        <field name="model">sr.public.holiday</field>
        <field name="arch" type="xml">
            <list string="Surinaamse Feestdagen" default_order="date">
                <field name="date"/>
                <field name="name"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ──────────────────────────────────────────────────── -->
    <record id="sr_public_holiday_view_form" model="ir.ui.view">
        <field name="name">sr.public.holiday.form</field>
        <field name="model">sr.public.holiday</field>
        <field name="arch" type="xml">
            <form string="Surinaamse Feestdag">
                <sheet>
                    <group>
                        <field name="date"/>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────── -->
    <record id="action_sr_public_holiday" model="ir.actions.act_window">
        <field name="name">Surinaamse Feestdagen</field>
        <field name="res_model">sr.public.holiday</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <!-- ── Menu-item onder SR Payroll Configuratie ────────────────────── -->
    <menuitem
        id="menu_sr_public_holiday"
        name="Feestdagen"
        parent="l10n_sr_hr_payroll.menu_sr_config_root"
        action="action_sr_public_holiday"
        sequence="10"/>
</odoo>
