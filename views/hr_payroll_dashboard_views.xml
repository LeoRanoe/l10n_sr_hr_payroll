<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════
         Suriname Payroll Dashboard  (l10n_sr_hr_payroll)
         Toont loonstroken geboekt onder de SR-loonstructuur.
         Zichtbaar via Payroll ▸ Suriname ▸ Loonstroken SR
    ══════════════════════════════════════════════════════════════════ -->

    <!-- Aangepaste lijstweergave: SR-kolommen (loontype, LB, AOV, netto) -->
    <record id="view_hr_payslip_sr_list" model="ir.ui.view">
        <field name="name">hr.payslip.sr.list</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <list string="Loonstroken Suriname" sample="1" duplicate="0">
                <field name="company_id" column_invisible="True"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="number" decoration-bf="1" readonly="state not in ['draft', 'verify']"/>
                <field name="employee_id" widget="many2one_avatar_user" readonly="state not in ['draft', 'verify']"/>
                <field name="payslip_run_id" string="Batch" optional="hide" readonly="state not in ['draft', 'verify']"/>
                <field name="date_from" string="Van" readonly="state in ['cancel', 'done', 'paid']"/>
                <field name="date_to" string="T/m" readonly="state in ['cancel', 'done', 'paid']"/>
                <field name="struct_id" string="Structuur" optional="hide" readonly="state in ['cancel', 'done', 'paid']"/>
                <field name="basic_wage" string="Basisloon" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show"/>
                <field name="gross_wage" string="Bruto" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show"/>
                <field name="net_wage" string="Netto" widget="monetary" options="{'currency_field': 'currency_id'}" decoration-bf="1"/>
                <button name="action_preview_sr_payslip" type="object" string="HTML" icon="fa-eye"/>
                <button name="action_print_sr_payslip" type="object" string="PDF" icon="fa-file-pdf-o"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-warning="state == 'verify'"
                    decoration-success="state == 'done'"
                    decoration-primary="state == 'paid'"
                    string="Status"/>
            </list>
        </field>
    </record>

    <!-- ── Search view met filters en groepering ──────────────────────── -->
    <record id="view_hr_payslip_sr_search" model="ir.ui.view">
        <field name="name">hr.payslip.sr.search</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <search string="Zoek Loonstroken SR">
                <field name="employee_id" string="Werknemer"/>
                <field name="number" string="Referentie"/>
                <field name="payslip_run_id" string="Batch"/>
                <separator/>
                <filter name="filter_current_period" string="Huidige Periode"
                    domain="[('date_from', '&lt;=', context_today().strftime('%%Y-%%m-%%d')),
                             ('date_to', '&gt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <filter name="filter_draft" string="Concept"
                    domain="[('state', '=', 'draft')]"/>
                <filter name="filter_verify" string="Te Controleren"
                    domain="[('state', '=', 'verify')]"/>
                <filter name="filter_done" string="Bevestigd"
                    domain="[('state', '=', 'done')]"/>
                <filter name="filter_paid" string="Betaald"
                    domain="[('state', '=', 'paid')]"/>
                <separator/>
                <group string="Groeperen" expand="0">
                    <filter name="group_employee" string="Werknemer"
                        context="{'group_by': 'employee_id'}"/>
                    <filter name="group_state" string="Status"
                        context="{'group_by': 'state'}"/>
                    <filter name="group_date_from" string="Periode"
                        context="{'group_by': 'date_from:month'}"/>
                    <filter name="group_batch" string="Batch"
                        context="{'group_by': 'payslip_run_id'}"/>
                    <filter name="group_department" string="Afdeling"
                        context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Kanban view voor snel overzicht ──────────────────────────── -->
    <record id="view_hr_payslip_sr_kanban" model="ir.ui.view">
        <field name="name">hr.payslip.sr.kanban</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <kanban sample="1" default_group_by="state">
                <field name="employee_id"/>
                <field name="number"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="basic_wage"/>
                <field name="net_wage"/>
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex align-items-center mb-1">
                            <field name="employee_id" widget="many2one_avatar_user"/>
                        </div>
                        <field name="number" class="fw-bold"/>
                        <div class="text-muted small">
                            <field name="date_from"/> – <field name="date_to"/>
                        </div>
                        <div class="d-flex justify-content-between mt-2">
                            <span class="text-muted">Netto:</span>
                            <field name="net_wage" widget="monetary"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Pivot view voor analyse ──────────────────────────────────── -->
    <record id="view_hr_payslip_sr_pivot" model="ir.ui.view">
        <field name="name">hr.payslip.sr.pivot</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <pivot string="Loonstroken Analyse" sample="1">
                <field name="employee_id" type="row"/>
                <field name="date_from" type="col" interval="month"/>
                <field name="basic_wage" type="measure"/>
                <field name="gross_wage" type="measure"/>
                <field name="net_wage" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Actievenster: gefilterd op SR-loonstructuur -->
    <record id="action_sr_payslip_dashboard" model="ir.actions.act_window">
        <field name="name">Loonstroken Suriname</field>
        <field name="res_model">hr.payslip</field>
        <field name="view_mode">list,kanban,pivot,form</field>
        <field name="view_id" ref="view_hr_payslip_sr_list"/>
        <field name="search_view_id" ref="view_hr_payslip_sr_search"/>
        <field name="domain" eval="[('struct_id', '=', ref('l10n_sr_hr_payroll.sr_payroll_structure'))]"/>
        <field name="context" eval="{'default_struct_id': ref('l10n_sr_hr_payroll.sr_payroll_structure'), 'search_default_filter_current_period': 1}"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Nog geen Surinaamse loonstroken gevonden.</p>
            <h3>Loonstroken Suriname — Wet Loonbelasting</h3>
            <p>
                Dit is een <strong>gefilterd overzicht</strong> van alle loonstroken die verwerkt zijn
                met de structuur <em>Suriname — Normaal Loon (Artikel 14 WLB)</em>.
                Het zijn <strong>dezelfde loonstroken</strong> als in
                <em>Loonstroken &#x2192; Alle loonstroken</em> — alleen vooraf gefilterd op de SR-structuur.
            </p>
            <h4>Verschil met Loonstroken &#x2192; Alle loonstroken?</h4>
            <ul>
                <li><strong>Alle loonstroken</strong> toont loonstroken van <em>alle</em> loonstructuren, ook andere landen of structuurtypen.</li>
                <li><strong>Loonstroken SR</strong> toont alleen de Surinaamse Art. 14 loonstroken — overzichtelijker als je uitsluitend met de SR module werkt.</li>
            </ul>
            <p>
                Nieuwe loonstrook aanmaken? Klik op <strong>+ Nieuw</strong> — de structuur
                <em>Suriname — Normaal Loon (Wet Loonbelasting)</em> wordt automatisch geselecteerd.
            </p>
        </field>
    </record>

    <!-- Menuitem: Payroll ▸ Suriname ▸ Loonstroken SR -->
    <menuitem
        id="menu_sr_payroll_root"
        name="Suriname"
        parent="hr_payroll.menu_hr_payroll_payslips"
        sequence="90"
        groups="hr_payroll.group_hr_payroll_user,l10n_sr_hr_payroll.group_sr_payroll_accountant_export,base.group_system"/>

    <menuitem
        id="menu_sr_payslip_dashboard"
        name="Loonstroken SR"
        parent="menu_sr_payroll_root"
        action="action_sr_payslip_dashboard"
        sequence="10"
        groups="hr_payroll.group_hr_payroll_user"/>

    <!-- ══════════════════════════════════════════════════════════════════
         Loonstrookformulier uitbreiding: voeg afdruk- en voorbeeldknoppen toe
         Zichtbaar als stat-knoppen rechts bovenaan het payslip-formulier.
         Alleen getoond voor loonstroken met de SR-loonstructuur.
    ══════════════════════════════════════════════════════════════════ -->
    <record id="hr_payslip_sr_form_buttons" model="ir.ui.view">
        <field name="name">hr.payslip.sr.form.buttons</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='struct_id']" position="after">
                <field
                    name="sr_payslip_layout"
                    invisible="not sr_is_sr_struct"
                    readonly="state in ['cancel', 'done', 'paid']"
                    help="Kies per SR-loonstrook welke layout werknemers of payrollgebruikers te zien krijgen."/>
            </xpath>
            <!-- Voeg afdruk- en voorbeeldknoppen toe aan de bestaande button_box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="sr_is_sr_struct" invisible="1"/>
                <button
                    name="action_print_sr_payslip"
                    string="PDF Loonstrook"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-print"
                    invisible="not sr_is_sr_struct"
                    help="Druk de Surinaamse loonstrook af als PDF (Artikel 14 WLB)"/>
                <button
                    name="action_preview_sr_payslip"
                    string="HTML-weergave"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-eye"
                    invisible="not sr_is_sr_struct"
                    help="Bekijk de loonstrook als HTML — geen download vereist"/>
            </xpath>
        </field>
    </record>

    <record id="hr_payslip_sr_form_fiscal_overview" model="ir.ui.view">
        <field name="name">hr.payslip.sr.form.fiscal.overview</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='salary_computation']" position="after">
                <page string="SR Fiscaal Overzicht" name="sr_fiscal_overview" invisible="not sr_is_sr_struct">
                    <group col="4">
                        <group string="Bruto / Netto Samenvatting" class="o_form_fw_labels">
                            <field name="sr_bruto_totaal_display" widget="monetary" readonly="1"/>
                            <field name="sr_heffingskorting_display" widget="monetary" readonly="1"/>
                            <field name="sr_lb_totaal_display" widget="monetary" readonly="1"/>
                            <field name="sr_aov_totaal_display" widget="monetary" readonly="1"/>
                            <field name="sr_inhoudingen_totaal_display" widget="monetary" readonly="1"/>
                            <field name="sr_netto_totaal_display" widget="monetary" readonly="1"/>
                        </group>
                        <group string="Uren Specificatie" class="o_form_fw_labels">
                            <field name="sr_total_worked_days" readonly="1"/>
                            <field name="sr_total_worked_hours" widget="float_time" readonly="1"/>
                            <field name="sr_regular_hours" widget="float_time" readonly="1"/>
                            <field name="sr_overtime_hours_150" widget="float_time" readonly="1"/>
                            <field name="sr_overtime_hours_200" widget="float_time" readonly="1"/>
                            <field name="sr_unpaid_extra_hours" widget="float_time" readonly="1"/>
                        </group>
                    </group>

                          <group string="Valutasnapshot"
                           invisible="not sr_frozen_contract_currency_id or sr_frozen_contract_currency_id.name == 'SRD'">
                        <group>
                            <field name="sr_frozen_contract_currency_id" readonly="1"
                                   options="{'no_open': True}"/>
                            <field name="sr_exchange_rate" readonly="1" digits="[16, 6]"/>
                            <field name="sr_netto_bronvaluta" readonly="1"/>
                        </group>
                        <group>
                            <field name="sr_frozen_netto_display_mode" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Momentopname Gewerkte Dagen"/>
                    <field name="worked_days_line_ids" readonly="1" nolabel="1">
                        <list string="Momentopname Gewerkte Dagen" create="0" delete="0">
                            <field name="work_entry_type_id" readonly="1"/>
                            <field name="name" readonly="1"/>
                            <field name="number_of_days" readonly="1" sum="Totaal Dagen"/>
                            <field name="number_of_hours" widget="float_time" readonly="1" sum="Totaal Uren"/>
                            <field name="amount" readonly="1" sum="Totaal Bedrag"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
