<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Suriname Payroll — Contract Formulier Uitbreiding
        Voegt het tabblad "Suriname Loon" toe aan het contract formulier.

        Vaste loon regels table (sr_vaste_regels):
          Eindgebruiker beheert zelf toeslagen en inhoudingen per werknemer.
          Categorieën:
            belastbaar  — telt mee in Art. 14 loonbelastinggrondslag
            vrijgesteld — Art. 10 WLB belastingvrij voordeel
                        aftrek_belastingvrij — Art. 10f, verlaagt LB + AOV grondslag
                        inhouding   — netto aftrek zonder effect op LB/AOV

        INFO — Eenmalige/variabele betalingen via Payslip inputs
        INFO — Art. 14 tarieven referentietabel
        LIVE — Live rekenvoorbeeld (geschatte loonstrook)
    -->
    <record id="hr_contract_sr_view_form" model="ir.ui.view">
        <field name="name">hr.contract.sr.form</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Suriname Payroll" name="sr_payroll_tab">

                    <div class="alert alert-info d-flex align-items-center mb-3" role="alert">
                        <div>
                            <strong><i class="fa fa-info-circle"/> Artikel 14 WLB — Actief</strong>
                            <span class="text-muted ms-2">
                                Contractdata uit deze tab stroomt door naar werkboekingen, loonstroken en het rekenvoorbeeld.
                            </span>
                        </div>
                    </div>

                    <notebook>
                        <page string="Fiscale Data" name="sr_fiscale_data_tab">
                            <group string="Basisloon &amp; Verloning" name="sr_basis_verloning">
                                <group>
                                    <field name="sr_contract_currency"
                                           options="{'no_create': True, 'no_open': True}"
                                           string="Contractvaluta"
                                           help="Kies de valuta van het basisloon. Wordt omgerekend naar SRD via de dagkoers in de Payroll Instellingen."/>
                                     <field name="wage" widget="monetary" options="{'currency_field': 'sr_contract_currency'}" required="1"/>
                                    <field name="sr_salary_type"
                                           widget="radio"
                                           string="Belastingtype"
                                           required="1"/>
                                    <field name="sr_hourly_wage" readonly="1"
                                           help="Bruto uurloon berekend uit het basisloon (automatisch)."/>
                                </group>
                                <group>
                                    <div class="alert alert-warning border mb-0" role="alert"
                                         invisible="sr_contract_currency == False or sr_contract_currency.name == 'SRD'">
                                        Basisloon is in vreemde valuta. De contractpreview gebruikt de actuele koers uit SR Payroll Instellingen; de definitieve loonstrook bewaart daarna een bevroren `sr_exchange_rate` snapshot. Controleer of de koers actueel is.
                                    </div>
                                    <div class="alert alert-danger border mb-0" role="alert" invisible="wage &gt; 0">
                                        Een actief SR payroll-contract vereist een positief basisloon. Zonder loon worden uurloon, overwerk en LB/AOV geblokkeerd.
                                    </div>
                                    <div class="alert alert-light border mb-0" role="status" invisible="sr_salary_type != 'monthly'">
                                        <strong>Maandloon:</strong> 12 periodes per jaar. Uurloon = basisloon ÷ 173,33. De AOV franchise uit SR Payroll Instellingen wordt toegepast.
                                    </div>
                                    <div class="alert alert-light border mb-0" role="status" invisible="sr_salary_type != 'fn'">
                                        <strong>FN:</strong> 26 periodes per jaar. Uurloon = basisloon ÷ 80. De payroll-engine past geen AOV franchise toe en valideert tegen de 2026 FN-kalender.
                                    </div>
                                </group>
                            </group>

                            <group string="Gezin &amp; AKB" name="sr_gezin_akb">
                                <group>
                                    <field name="sr_aantal_kinderen"
                                           string="Aantal Kinderen (Art. 10h)"
                                           help="Aantal kinderen voor kinderbijslag vrijstelling. Wettelijk gemaximeerd op 4 kinderen in de 2026 release."/>
                                    <field name="sr_kinderbijslag_bedrag" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                                <group>
                                    <div class="text-muted small pt-1">
                                        AKB is in 2026 beperkt tot <strong>SRD 250 per kind</strong>, maximaal <strong>SRD 1.000</strong> en maximaal <strong>4 kinderen</strong>. De vrijgestelde/belastbare splitsing wordt later automatisch op de loonstrook toegepast.
                                    </div>
                                </group>
                            </group>

                            <group string="Toelagen per Periode" name="sr_named_allowances">
                                <group>
                                    <field name="sr_vervoer_toelage" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="sr_representatie_toelage" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="sr_vrije_geneeskundige_behandeling" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                                <group>
                                    <div class="text-muted small pt-1">
                                        Deze snelle contractvelden schrijven door naar de onderliggende <strong>Vaste Loon Regels</strong>. Gebruik de tabel hieronder voor overige toelagen, inhoudingen en percentages.
                                    </div>
                                </group>
                            </group>

                            <group string="Overwerk &amp; Werkboekingen" name="sr_overwerk">
                                <group>
                                    <field name="sr_has_overtime_right"/>
                                </group>
                                <group>
                                    <div class="alert alert-light border mb-0" role="status" invisible="sr_has_overtime_right">
                                        <strong>Geen overwerkrecht:</strong> overwerkuren worden geregistreerd
                                        maar er worden geen variabele overwerkinputs aangemaakt op de loonstrook.
                                        Gebruik de <em>Vaste Loon Regels</em> hieronder voor een vaste toeslag.
                                    </div>
                                    <div class="alert alert-light border mb-0" role="status" invisible="not sr_has_overtime_right">
                                        <strong>Met overwerkrecht:</strong> werk entries met een overwerk-type
                                        worden automatisch geclassificeerd als 150% (werkdag) of 200% (zon/feestdag)
                                        en als aparte inputs op de loonstrook gesynchroniseerd.
                                    </div>
                                </group>
                            </group>

                            <separator string="Overige Vaste Toelagen &amp; Inhoudingen"/>
                            <div class="text-muted small mb-2">
                                Dit is de fiscale bron voor vaste toelagen en inhoudingen op het contract.
                                Kies per regel de categorie: <strong>Belastbaar</strong>, <strong>Belastingvrij</strong>,
                                <strong>Aftrek Belastingvrij</strong> of <strong>Inhouding</strong>.
                                Bij een gekozen <strong>Type</strong> bepaalt het type altijd de fiscale categorie.
                            </div>

                            <field name="sr_vaste_regels" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="type_id"
                                           placeholder="Selecteer een type..."
                                           options="{'no_create': False, 'no_create_edit': False}"/>
                                    <field name="name"
                                           placeholder="Automatisch of handmatig..."/>
                                    <field name="sr_categorie" readonly="type_id"/>
                                    <field name="amount_type" string="Berekening"/>
                                    <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"
                                           column_invisible="False"
                                           readonly="amount_type == 'percentage'"/>
                                    <field name="percentage"
                                           string="%"
                                           column_invisible="False"
                                           readonly="amount_type != 'percentage'"/>
                                    <field name="percentage_base"
                                           string="% Basis"
                                           column_invisible="False"
                                           readonly="amount_type != 'percentage'"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                        </page>

                        <page string="Controle &amp; Voorbeeld" name="sr_controle_preview_tab">
                            <group string="Eenmalige &amp; Variabele Betalingen (via Loonstrook)" name="sr_payslip_info">
                                <div colspan="2" class="alert alert-info small" role="status">
                                    <strong><i class="fa fa-lightbulb"/> Hoe eigen loon codes aanmaken?</strong><br/>
                                    Bedragen die niet elke periode hetzelfde zijn, zoals vakantietoelage,
                                    bonus of gratificatie, beheer je via <strong>Loonstrook inputs</strong>.
                                    <strong>Overwerk</strong> komt normaal automatisch uit <strong>Werkboekingen</strong>
                                    wanneer het contract overwerkrecht heeft en het werkboekingstype als SR overwerk staat ingesteld:
                                    <ol class="mt-1 mb-0 ps-3">
                                        <li>Ga naar <strong>Configuratie → Salaris → Andere invoertypen</strong></li>
                                        <li>Maak een nieuwe loon code aan (bijv. "Olie Toeslag Variabel")</li>
                                        <li>Stel de <strong>SR Loon Categorie</strong> in (belastbaar / vrijgesteld / overwerk / vakantie / gratificatie / bijzondere beloning)</li>
                                        <li>Voeg het bedrag toe bij het aanmaken van de loonstrook</li>
                                    </ol>
                                    <div class="mt-2 pt-2 border-top">
                                        <strong>Vooringestelde codes:</strong>
                                        SR_IN_OVERWERK_150 (Werkdag overwerk) ·
                                        SR_IN_OVERWERK_200 (Zon/feestdag overwerk) ·
                                        SR_IN_OVERWERK (oud/generiek) ·
                                        SR_IN_VAKANTIE (Vakantietoelage Art. 10i) ·
                                        SR_IN_GRAT (Gratificatie Art. 10j) ·
                                        SR_IN_BIJZ (Bijzondere Beloning Art. 17) ·
                                        SR_IN_VRIJ (Vrije Vergoeding) ·
                                        SR_IN_AFTREK (Extra Inhouding)
                                    </div>
                                </div>
                            </group>

                            <group string="Referentie — Artikel 14 Tariefschijven" name="sr_tarieven">
                                <div colspan="2" class="py-1">
                                    <field name="sr_tax_bracket_html" nolabel="1" readonly="1"/>
                                </div>
                            </group>

                            <group string="Rekenvoorbeeld — Geschatte Loonstrook per Periode" name="sr_rekenvoorbeeld">
                                <div colspan="2" class="alert alert-warning small mb-2" role="status">
                                    <i class="fa fa-exclamation-triangle"/>&#160;<em>Schatting op basis van vaste contractwaarden. Eenmalige loonstrookinvoer zoals overwerk, vakantie of bonus is niet inbegrepen. Definitieve bedragen staan op de loonstrook.</em>
                                </div>
                                <group string="Bruto &amp; Belastbaar">
                                    <field name="sr_preview_bruto" readonly="1" widget="monetary" string="Bruto Loon (incl. vaste toelagen)"/>
                                    <field name="sr_preview_belastinggrondslag" readonly="1" widget="monetary" string="Grondslag voor Belasting"/>
                                    <field name="sr_preview_belastbaar_jaar" readonly="1" widget="monetary" string="Belastbaar Jaarloon (Art. 14)"/>
                                </group>
                                <group string="Geschatte Inhoudingen &amp; Netto">
                                    <field name="sr_preview_lb_periode" readonly="1" widget="monetary" string="In te houden Loonbelasting (Art. 14)"/>
                                    <field name="sr_preview_aov_periode" readonly="1" widget="monetary" string="AOV Inhouding per Periode (4%)"/>
                                    <field name="sr_preview_netto" readonly="1" widget="monetary" string="Geschat Nettoloon" class="fw-bold text-success"/>
                                </group>
                            </group>

                            <group string="Berekeningsdetail — Stap-voor-Stap (Art. 14)" name="sr_debug_panel">
                                <div colspan="2" class="text-muted small mb-2">
                                    Alle tussenliggende berekenstappen voor controle en verificatie.
                                    Gebruik dit om de loonstrookbedragen te begrijpen en te vergelijken.
                                </div>
                                <div colspan="2">
                                    <field name="sr_preview_breakdown_html" nolabel="1" readonly="1"/>
                                </div>
                            </group>
                        </page>
                    </notebook>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
