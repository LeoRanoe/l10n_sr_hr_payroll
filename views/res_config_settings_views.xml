<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_sr_payroll" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sr.payroll</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="65"/>
        <field name="inherit_id" ref="hr_payroll.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Suriname Payroll" string="Suriname Payroll" name="l10n_sr_hr_payroll" groups="hr_payroll.group_hr_payroll_manager">
                    <block title="Suriname Payroll Configuratie" id="sr_payroll_settings_block">
                        <div class="text-muted mb-3">
                            Dit is het <strong>dagelijkse beheerscherm</strong> voor actuele SR payrollwaarden.
                            Deze instellingen worden persistent in <code>ir.config_parameter</code> opgeslagen en direct door de payrollberekening gebruikt.
                        </div>
                        <div class="alert alert-info" role="alert">
                            Gebruik dit scherm voor actuele bedragen en tarieven. Technische referentiecodes en historische parameterregels zijn alleen nodig voor implementatie, controle en toekomstige uitbreidingen.
                        </div>
                        <notebook>
                            <page string="Belasting">
                                <group>
                                    <group string="Artikel 12 t/m 14">
                                        <field name="sr_currency_id" invisible="1"/>
                                        <field name="belastingvrij_jaar" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                        <field name="forfaitaire_pct"/>
                                        <field name="forfaitaire_max_jaar" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                        <field name="schijf_1_grens" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                        <field name="schijf_2_grens" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                        <field name="schijf_3_grens" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                    </group>
                                    <group string="Tarieven &amp; inhoudingen">
                                        <field name="tarief_1"/>
                                        <field name="tarief_2"/>
                                        <field name="tarief_3"/>
                                        <field name="tarief_4"/>
                                        <field name="aov_tarief"/>
                                        <field name="aov_franchise_maand" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                        <field name="bijz_beloning_max" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                    </group>
                                </group>
                                <div class="alert alert-secondary mt-3 mb-0" role="alert">
                                    <strong>AOV franchise:</strong> deze waarde geldt alleen voor <strong>maandloon</strong>.
                                    Bij <strong>FN / Fortnight</strong> wordt in de payroll-engine automatisch geen franchise toegepast.
                                </div>
                                <div class="alert alert-light border mt-3 mb-0" role="alert">
                                    <strong>Heffingskorting:</strong> wordt als <strong>aparte netto-credit</strong> toegepast.
                                    Voor maandloon geldt de ingevoerde maandwaarde; voor <strong>FN / Fortnight</strong> rekent de payroll-engine deze pro-rata om naar 12/26 van de maandwaarde.
                                </div>
                            </page>
                            <page string="AKB">
                                <group>
                                    <group string="Algemene Kinderbijslag">
                                        <field name="akb_per_kind" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                        <field name="akb_max_bedrag" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                    </group>
                                    <group string="Toelichting">
                                        <div class="text-muted">
                                            Maximaal 4 kinderen worden volledig vrijgesteld bij de standaardinstelling van SRD 250 per kind en SRD 1.000 per maand.
                                        </div>
                                    </group>
                                </group>
                            </page>
                            <page string="Overwerk">
                                <group>
                                    <group string="Schijfgrenzen">
                                        <field name="overwerk_schijf_1_grens" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                        <field name="overwerk_schijf_2_grens" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                    </group>
                                    <group string="Tarieven">
                                        <field name="overwerk_tarief_1"/>
                                        <field name="overwerk_tarief_2"/>
                                        <field name="overwerk_tarief_3"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Vermenigvuldigers">
                                        <field name="overwerk_factor_150"/>
                                        <field name="overwerk_factor_200"/>
                                    </group>
                                    <group>
                                        <div class="text-muted">
                                            De vermenigvuldigers bepalen het bruto overwerkbedrag per uur:
                                            uurloon × factor.<br/>
                                            <strong>150%</strong> geldt voor werkdagen (Ma–Za).<br/>
                                            <strong>200%</strong> geldt voor zondag of een wettelijke feestdag.
                                        </div>
                                    </group>
                                </group>
                            </page>
                            <page string="Loonstroken">
                                <group>
                                    <group string="Standaard weergave">
                                        <field name="sr_default_payslip_layout"/>
                                    </group>
                                    <group string="Toelichting">
                                        <div class="text-muted">
                                            Nieuwe SR-loonstroken nemen deze layout standaard over.
                                            Payroll kan de keuze nog per loonstrook aanpassen in het loonstrookformulier.
                                        </div>
                                    </group>
                                </group>
                                <div class="alert alert-secondary mt-3 mb-0" role="alert">
                                    <strong>Werknemer Overzichtelijk</strong> toont een rustige loonstrook met bruto, inhoudingen en netto.<br/>
                                    <strong>Compact</strong> gebruikt een kortere één-pagina layout voor snelle controle.<br/>
                                    <strong>Uitgebreid</strong> behoudt de volledige Artikel 14 en AOV detailberekening.
                                </div>
                            </page>
                            <page string="Technisch / Audit" groups="base.group_system">
                                <group>
                                    <group string="Beheerde heffingskorting">
                                        <field name="heffingskorting" widget="monetary" options="{'currency_field': 'sr_currency_id'}"/>
                                    </group>
                                    <group string="Toelichting">
                                        <div class="text-muted">
                                            Deze tab is alleen voor systeembeheer. De heffingskorting wordt als afzonderlijke nettocredit beheerd en verandert de Art. 14 LB-schijfbepaling zelf niet.
                                        </div>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_res_config_settings_sr_payroll" model="ir.actions.act_window">
        <field name="name">SR Payroll Instellingen</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'l10n_sr_hr_payroll', 'bin_size': False}</field>
    </record>

    <menuitem
        id="menu_sr_settings"
        name="SR Payroll Instellingen"
        parent="l10n_sr_hr_payroll.menu_sr_config_root"
        action="action_res_config_settings_sr_payroll"
        sequence="5"/>
</odoo>