<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Suriname Payroll — Work Entry formulier uitbreiding
        =====================================================
        Staat System Admins toe om gevalideerde work entries te bewerken
        en terug te zetten naar 'concept' voor correcties.

        Het standaard Odoo-formulier markeert alle velden readonly als
        state != 'draft'. Voor beheerders (base.group_system) wordt
        dit versoepeld zodat correcties mogelijk zijn.

        Tevens: 'Terug naar Concept (Admin)' knop voor snelle reset
        van gevalideerde entries zonder de regeneration wizard.
    -->
    <record id="hr_work_entry_view_form_sr_admin" model="ir.ui.view">
        <field name="name">hr.work.entry.form.sr.admin</field>
        <field name="model">hr.work.entry</field>
        <field name="inherit_id" ref="hr_work_entry.hr_work_entry_view_form"/>
        <field name="arch" type="xml">

            <!-- Voeg sr_is_admin toe als verborgen veld (nodig voor readonly-condities) -->
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="sr_is_admin" invisible="1"/>
            </xpath>

            <!-- Naam: ook bewerkbaar voor admin bij validated-status -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="readonly">state == 'validated' and not sr_is_admin</attribute>
            </xpath>

            <!-- Medewerker: ook bewerkbaar voor admin buiten draft -->
            <xpath expr="//field[@name='employee_id']" position="attributes">
                <attribute name="readonly">state != 'draft' and not sr_is_admin</attribute>
            </xpath>

            <!-- Work entry type: ook bewerkbaar voor admin bij validated -->
            <xpath expr="//field[@name='work_entry_type_id']" position="attributes">
                <attribute name="readonly">state == 'validated' and not sr_is_admin</attribute>
            </xpath>

            <!-- Startdatum: ook bewerkbaar voor admin buiten draft -->
            <xpath expr="//field[@name='date_start']" position="attributes">
                <attribute name="readonly">state != 'draft' and not sr_is_admin</attribute>
            </xpath>

            <!-- Einddatum: ook bewerkbaar voor admin buiten draft -->
            <xpath expr="//field[@name='date_stop']" position="attributes">
                <attribute name="readonly">state != 'draft' and not sr_is_admin</attribute>
            </xpath>

            <!-- Duur: ook bewerkbaar voor admin buiten draft -->
            <xpath expr="//field[@name='duration']" position="attributes">
                <attribute name="readonly">state != 'draft' and not sr_is_admin</attribute>
            </xpath>

            <!--
                Admin-knop: zet gevalideerde entry terug naar Concept.
                Zichtbaar alleen voor System Admins bij validated state.
                Bevestigingsdialoog ter voorkoming van onbedoeld gebruik.
            -->
            <xpath expr="//header/field[@name='state']" position="before">
                <button
                    string="↩ Terug naar Concept (Admin)"
                    name="action_sr_reset_to_draft"
                    type="object"
                    class="btn-warning"
                    invisible="state != 'validated' or not sr_is_admin"
                    confirm="Weet u zeker dat u deze gevalideerde work entry terug naar Concept wilt zetten? Loonstroken die al zijn verwerkt voor deze periode kunnen hierdoor incorrect worden."/>
            </xpath>

            <!-- Suriname overwerk &amp; audit sectie in het formulier -->
            <xpath expr="//field[@name='duration']" position="after">
                <separator string="Suriname Overwerk &amp; Registratie"/>
                <group name="sr_overtime_group" string="Overwerk Buckets">
                    <group>
                        <field name="sr_overtime_150"
                               readonly="state == 'validated' and not sr_is_admin"/>
                        <field name="sr_overtime_200"
                               readonly="state == 'validated' and not sr_is_admin"/>
                    </group>
                    <group>
                        <field name="sr_manual_override"
                               readonly="state == 'validated' and not sr_is_admin"/>
                        <field name="sr_entry_source"
                               readonly="state == 'validated' and not sr_is_admin"/>
                        <field name="sr_import_batch"
                               readonly="state == 'validated' and not sr_is_admin"
                               invisible="sr_entry_source != 'import'"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

    <!-- ── Tree/List view uitbreiding: overwerk-kolommen ──────────────── -->
    <record id="hr_work_entry_view_list_sr_overtime" model="ir.ui.view">
        <field name="name">hr.work.entry.list.sr.overtime</field>
        <field name="model">hr.work.entry</field>
        <field name="inherit_id" ref="hr_work_entry.hr_work_entry_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='duration']" position="after">
                <field name="sr_overtime_150" optional="show" string="OT 150% (u)"/>
                <field name="sr_overtime_200" optional="show" string="OT 200% (u)"/>
                <field name="sr_entry_source" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="hr_work_entry_type_view_form_sr_overtime" model="ir.ui.view">
        <field name="name">hr.work.entry.type.form.sr.overtime</field>
        <field name="model">hr.work.entry.type</field>
        <field name="inherit_id" ref="hr_work_entry.hr_work_entry_type_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='main_group']" position="after">
                <group string="Suriname Payroll" class="o_form_fw_labels">
                    <field name="sr_is_overtime"/>
                    <field name="sr_overtime_multiplier" invisible="not sr_is_overtime"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
