        <!-- ═══════════════════════════════════════════════════════════════
             LB + AOV OP BIJZONDERE BELONINGEN (seq 91–92)
             Art. 17 marginaal tarief methode (conform context):
               1. Bepaal reeds gebruikte jaarcap vrijstelling (YTD lookup)
               2. Combineer alle bijz. beloningen; vrijstelling aftrekken
                  - vakantie: min(2 × basisloon, resterende jaarcap)
                  - gratificatie: min(basisloon, resterende jaarcap) + prorata
                  - bijz_beloning: geen vrijstelling
               3. Eén gecombineerd belastbaar_bijz_totaal
               4. gemiddelde = belastbaar_bijz_totaal / periodes
               5. gecorrigeerd loon = regulier_gross + gemiddelde
               6. lb_bijz = lb_per_tijdvak(gecorrigeerd) - lb_per_tijdvak(regulier)
               7. Niet vermenigvuldigen met periodes (context: informatief)
             ═══════════════════════════════════════════════════════════════ -->

        <!-- ─────────────────────────────────────────────────────────
             91 — SR_LB_BIJZ: LB over bijzondere beloningen (Art. 17)
             Combineert vakantie + gratificatie + bijz_beloning.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_lb_bijz" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">Loonbelasting Bijzondere Beloningen (Art. 17)</field>
            <field name="code">SR_LB_BIJZ</field>
            <field name="sequence">91</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = any(
    inp.input_type_id.sr_categorie in ('vakantie', 'gratificatie', 'bijz_beloning')
    and inp.amount > 0
    for inp in payslip.input_line_ids
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# ── Art. 17: Marginaal tarief methode ───────────────────────────────────
# Geconsolideerde berekening via _sr_bijz_belastbaar_totaal helper.
belastbaar_bijz_totaal = payslip._sr_bijz_belastbaar_totaal()
if belastbaar_bijz_totaal &lt;= 0:
    result = 0.0
else:
    periodes = 12 if contract.sr_salary_type == 'monthly' else 26
    gross_per_tijdvak = categories['GROSS']
    aftrek_bv = contract._sr_resolve_regels('aftrek_belastingvrij')

    lb_normaal = payslip._sr_artikel14_lb(gross_per_tijdvak, aftrek_bv=aftrek_bv)
    gemiddelde = belastbaar_bijz_totaal / periodes
    gecorrigeerd = gross_per_tijdvak + gemiddelde
    lb_gecorr = payslip._sr_artikel14_lb(gecorrigeerd, aftrek_bv=aftrek_bv)
    lb_bijz = max(0.0, lb_gecorr - lb_normaal)
    result = -float_round(lb_bijz, precision_digits=2)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             92 — SR_AOV_BIJZ: AOV over bijzondere beloningen
             Issue 4: AOV = verschil per tijdvak, niet volledige bedrag.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_aov_bijz" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">AOV Bijzondere Beloningen</field>
            <field name="code">SR_AOV_BIJZ</field>
            <field name="sequence">92</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = any(
    inp.input_type_id.sr_categorie in ('vakantie', 'gratificatie', 'bijz_beloning')
    and inp.amount > 0
    for inp in payslip.input_line_ids
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# ── AOV over bijzondere beloningen ──────────────────────────────────────
# Geconsolideerde berekening via _sr_bijz_belastbaar_totaal helper.
belastbaar_bijz_totaal = payslip._sr_bijz_belastbaar_totaal()
if belastbaar_bijz_totaal &lt;= 0:
    result = 0.0
else:
    periodes = 12 if contract.sr_salary_type == 'monthly' else 26
    aov_tarief = payslip._rule_parameter('SR_AOV_TARIEF')
    aov_bijz = (belastbaar_bijz_totaal / periodes) * aov_tarief
    result = -float_round(aov_bijz, precision_digits=2)
            </field>
        </record>

        <!-- ═══════════════════════════════════════════════════════════════
             LB + AOV OP UITKERING INEENS (seq 93–94)
             Art. 17a: eigen tariefschijven 5%/15%/25%/35%/45%
             Geen belastingvrije som. AOV = 4% van het bedrag.
             ═══════════════════════════════════════════════════════════════ -->

        <!-- ─────────────────────────────────────────────────────────
             93 — SR_LB_17A: LB over uitkering ineens (Art. 17a)
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_lb_17a" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">Loonbelasting Uitkering Ineens (Art. 17a)</field>
            <field name="code">SR_LB_17A</field>
            <field name="sequence">93</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = any(
    inp.input_type_id.sr_categorie == 'uitkering_ineens'
    and inp.amount > 0
    for inp in payslip.input_line_ids
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# Art. 17a: eigen tariefschijven, geen belastingvrije som
s1 = payslip._rule_parameter('SR_17A_SCHIJF_1_GRENS')
s2 = payslip._rule_parameter('SR_17A_SCHIJF_2_GRENS')
s3 = payslip._rule_parameter('SR_17A_SCHIJF_3_GRENS')
s4 = payslip._rule_parameter('SR_17A_SCHIJF_4_GRENS')
r1 = payslip._rule_parameter('SR_17A_TARIEF_1')
r2 = payslip._rule_parameter('SR_17A_TARIEF_2')
r3 = payslip._rule_parameter('SR_17A_TARIEF_3')
r4 = payslip._rule_parameter('SR_17A_TARIEF_4')
r5 = payslip._rule_parameter('SR_17A_TARIEF_5')

bedrag = sum(
    inp.amount for inp in payslip.input_line_ids
    if inp.input_type_id.sr_categorie == 'uitkering_ineens' and inp.amount > 0
)

if bedrag &lt;= s1:
    lb = bedrag * r1
elif bedrag &lt;= s2:
    lb = s1 * r1 + (bedrag - s1) * r2
elif bedrag &lt;= s3:
    lb = s1 * r1 + (s2 - s1) * r2 + (bedrag - s2) * r3
elif bedrag &lt;= s4:
    lb = s1 * r1 + (s2 - s1) * r2 + (s3 - s2) * r3 + (bedrag - s3) * r4
else:
    lb = s1 * r1 + (s2 - s1) * r2 + (s3 - s2) * r3 + (s4 - s3) * r4 + (bedrag - s4) * r5

result = -float_round(lb, precision_digits=2)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             94 — SR_AOV_17A: AOV over uitkering ineens (Art. 17a)
