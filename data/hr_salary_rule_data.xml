        <!-- ═══════════════════════════════════════════════════════════════
             LB + AOV OP BIJZONDERE BELONINGEN (seq 91–92)
             Art. 17 marginaal tarief methode:
               1. vrijstelling aftrekken (vakantie/grat: min(loon, 10.016))
               2. gemiddelde bijstelling per tijdvak berekenen
               3. gecorrigeerd loon = regulier_gross + gemiddelde
               4. lb_tijdvak(gecorrigeerd) - lb_tijdvak(regulier)
               5. lb_bijz = verschil × periodes
             ═══════════════════════════════════════════════════════════════ -->

        <!-- ─────────────────────────────────────────────────────────
             91 — SR_LB_BIJZ: LB over bijzondere beloningen (Art. 17)
             Combineert vakantie + gratificatie + bijz_beloning.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_lb_bijz" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">Loonbelasting Bijzondere Beloningen (Art. 17)</field>
            <field name="code">SR_LB_BIJZ</field>
            <field name="sequence">91</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = any(
    inp.input_type_id.sr_categorie in ('vakantie', 'gratificatie', 'bijz_beloning')
    and inp.amount > 0
    for inp in payslip.input_line_ids
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# ── Hulpfunctie: Art. 14 LB per tijdvak ─────────────────────────────────
# Hergebruikt dezelfde parameterlogica als SR_LB zodat beide regels
# altijd consistent zijn. Inclusief aftrek_bv (Art. 10f).
def _lb_per_tijdvak(bruto_per_tijdvak, periodes, prm, aftrek_bv=0.0):
    bruto_jaar = bruto_per_tijdvak * periodes
    aftrek_bv_jaar = aftrek_bv * periodes
    adjusted = max(0.0, bruto_jaar - aftrek_bv_jaar)
    forfaitaire = min(adjusted * prm['for_pct'], prm['for_max'])
    belastbaar = max(0.0, adjusted - prm['bvsom'] - forfaitaire)
    s1, s2, s3 = prm['s1'], prm['s2'], prm['s3']
    r1, r2, r3, r4 = prm['r1'], prm['r2'], prm['r3'], prm['r4']
    if belastbaar &lt;= s1:
        lb_j = belastbaar * r1
    elif belastbaar &lt;= s2:
        lb_j = s1 * r1 + (belastbaar - s1) * r2
    elif belastbaar &lt;= s3:
        lb_j = s1 * r1 + (s2 - s1) * r2 + (belastbaar - s2) * r3
    else:
        lb_j = s1 * r1 + (s2 - s1) * r2 + (s3 - s2) * r3 + (belastbaar - s3) * r4
    hk_j = prm['hk_maand'] * 12
    return max(0.0, lb_j - hk_j) / periodes

periodes = 12 if contract.sr_salary_type == 'monthly' else 26
gross_per_tijdvak = categories['GROSS']
aftrek_bv = contract._sr_resolve_regels('aftrek_belastingvrij')
vrijstelling_max = payslip._rule_parameter('SR_BIJZ_VRIJSTELLING_MAX')

# Bug C fix: maandequivalent voor FN-werkers
wage_maand = (contract.wage or 0.0) * periodes / 12

prm = {
    'for_pct':  payslip._rule_parameter('SR_FORFAITAIRE_PCT'),
    'for_max':  payslip._rule_parameter('SR_FORFAITAIRE_MAX_JAAR'),
    'bvsom':    payslip._rule_parameter('SR_BELASTINGVRIJ_JAAR'),
    's1':       payslip._rule_parameter('SR_SCHIJF_1_GRENS'),
    's2':       payslip._rule_parameter('SR_SCHIJF_2_GRENS'),
    's3':       payslip._rule_parameter('SR_SCHIJF_3_GRENS'),
    'r1':       payslip._rule_parameter('SR_TARIEF_1'),
    'r2':       payslip._rule_parameter('SR_TARIEF_2'),
    'r3':       payslip._rule_parameter('SR_TARIEF_3'),
    'r4':       payslip._rule_parameter('SR_TARIEF_4'),
    'hk_maand': payslip._rule_parameter('SR_HEFFINGSKORTING_MAAND'),
}

lb_normaal = _lb_per_tijdvak(gross_per_tijdvak, periodes, prm, aftrek_bv)
lb_totaal = 0.0

for inp in payslip.input_line_ids:
    cat = inp.input_type_id.sr_categorie
    if cat not in ('vakantie', 'gratificatie', 'bijz_beloning'):
        continue
    bruto = inp.amount
    if bruto &lt;= 0:
        continue

    # Art. 10i/j: vrijstelling = min(maandloon, max per jaar)
    if cat in ('vakantie', 'gratificatie'):
        vrijstelling = min(wage_maand, vrijstelling_max)
        # Bug D: gratificatie pro-rata voor onvolledig dienstjaar (Art. 10j)
        if cat == 'gratificatie' and payslip.date_to and contract.date_start:
            year_start = payslip.date_to.replace(month=1, day=1)
            service_start = max(contract.date_start, year_start)
            months = (payslip.date_to.year - service_start.year) * 12 + payslip.date_to.month - service_start.month + 1
            months = min(12, max(1, months))
            vrijstelling = vrijstelling * months / 12
    else:
        # bijz_beloning: geen vaste vrijstelling (Art. 17)
        vrijstelling = 0.0

    belastbaar_bijz = max(0.0, bruto - vrijstelling)
    if belastbaar_bijz &lt;= 0:
        continue

    # Art. 17: marginaal tarief methode
    gemiddelde = belastbaar_bijz / periodes
    gecorrigeerd = gross_per_tijdvak + gemiddelde
    lb_gecorr = _lb_per_tijdvak(gecorrigeerd, periodes, prm, aftrek_bv)
    lb_bijz = max(0.0, lb_gecorr - lb_normaal) * periodes
    lb_totaal += lb_bijz

result = -float_round(lb_totaal, precision_digits=2)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             92 — SR_AOV_BIJZ: AOV over bijzondere beloningen
             4% over het belastbaar deel (na vrijstelling).
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_aov_bijz" model="hr.salary.rule">
