<?xml version="1.0" encoding="utf-8"?>
<!--
    Suriname Salarisregels — Artikel 14 Wet Loonbelasting 2026
    ==========================================================
    Uitvoervolgorde (sequence):
      10  BASIC          — Bruto loon (contract.wage)
      20  SR_ALW         — Belastbare toelagen (contract, categorie=belastbaar)
      21  SR_KB_BELAST   — Kinderbijslag belastbaar deel (Art. 10h)
      23  SR_INPUT_BELASTB — Belastbare toelagen (payslip inputs)
      30  GROSS          — Bruto belastbaar (BASIC + ALW)
      50  SR_LB          — Loonbelasting Artikel 14 BRUTO (negatief)
      55  SR_HK          — Heffingskorting (positief credit)
      60  SR_AOV         — AOV bijdrage (negatief)
      65  SR_AFTREK_BV   — Aftrek belastingvrij inhoudingen (negatief)
      70  SR_PENSIOEN    — Vaste inhoudingen (contract, categorie=inhouding)
      73  SR_INPUT_AFTREK — Overige inhoudingen (payslip inputs)
      80  SR_KINDBIJ     — Vrijgestelde vergoedingen excl. kinderbijslag
      81  SR_KB_VRIJ     — Kinderbijslag vrijgesteld deel (Art. 10h)
      82  SR_INPUT_VRIJ  — Vrijgestelde vergoedingen (payslip inputs)
      84-86              — Overwerk (Art. 17c)
      87-89              — Bijzondere beloningen bruto (vakantie/grat/bijz)
      91  SR_LB_BIJZ     — LB bijzondere beloningen (Art. 17)
      92  SR_AOV_BIJZ    — AOV bijzondere beloningen
     100  NET            — Nettoloon
-->
<odoo>
    <data noupdate="0">

        <!-- ─────────────────────────────────────────────────────────
             10 — BASIC: Bruto loon per periode
             Het brutoloon staat op het contract (contract.wage).
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_basic" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.BASIC"/>
            <field name="name">Bruto Loon</field>
            <field name="code">BASIC</field>
            <field name="sequence">10</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = contract.wage
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             20 — SR_ALW: Belastbare toelagen (contract.sr_vaste_regels)
             Som van alle vaste regels met categorie 'belastbaar'.
             Telt mee in GROSS → Art. 14 loonbelastinggrondslag.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_toelagen" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="name">Belastbare Toelagen (Contract)</field>
            <field name="code">SR_ALW</field>
            <field name="sequence">20</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = contract._sr_resolve_regels('belastbaar') > 0
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = contract._sr_resolve_regels('belastbaar')
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             21 — SR_KB_BELAST: Kinderbijslag belastbaar deel (Art. 10h)
             Bedrag boven de vrijstelling (max SRD 125/kind, 500/mnd).
             Telt mee in GROSS → Art. 14 loonbelastinggrondslag.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_kb_belastbaar" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="name">Kinderbijslag Belastbaar Deel (Art. 10h)</field>
            <field name="code">SR_KB_BELAST</field>
            <field name="sequence">21</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
max_kind = payslip._rule_parameter('SR_KINDBIJ_MAX_KIND_MAAND')
max_maand = payslip._rule_parameter('SR_KINDBIJ_MAX_MAAND')
kb = contract._sr_kinderbijslag_split(max_kind, max_maand)
result = kb['belastbaar'] > 0
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
max_kind = payslip._rule_parameter('SR_KINDBIJ_MAX_KIND_MAAND')
max_maand = payslip._rule_parameter('SR_KINDBIJ_MAX_MAAND')
kb = contract._sr_kinderbijslag_split(max_kind, max_maand)
result = kb['belastbaar']
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             30 — GROSS: Totaal belastbaar bruto loon
             Som van BASIC + ALW (inclusief toelagen + KB belastbaar).
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_gross" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.GROSS"/>
            <field name="name">Bruto Belastbaar Loon</field>
            <field name="code">GROSS</field>
            <field name="sequence">30</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = categories['BASIC'] + categories['ALW']
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             50 — SR_LB: Loonbelasting Artikel 14 WLB
             ─────────────────────────────────────────────────────────
             Berekening stappen:
               1. Bepaal het aantal periodes per jaar (12 of 26)
               2. Herbereken het bruto jaarloon
               3. Bereken forfaitaire beroepskosten aftrek
               4. Bereken het belastbaar jaarloon na aftrekken
               5. Bereken de belasting via tariefschijven
               6. Pas heffingskorting toe
               7. Deel terug door periodes voor periodebedrag
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_loonbelasting" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">Loonbelasting (Artikel 14 WLB)</field>
            <field name="code">SR_LB</field>
            <field name="sequence">50</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# Artikel 14 LB — BRUTO bedrag (vóór heffingskorting)
# Heffingskorting wordt apart getoond als SR_HK (seq 55)
aftrek_bv = contract._sr_resolve_regels('aftrek_belastingvrij')
result = -float_round(payslip._sr_artikel14_lb(categories['GROSS'], aftrek_bv=aftrek_bv), precision_digits=2)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             55 — SR_HK: Heffingskorting (Art. 14 WLB)
             ─────────────────────────────────────────────────────────
             Credit: vermindert de loonbelasting. Wordt apart getoond
             zodat de loonstrook transparant de bruto LB en HK toont.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_heffingskorting" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="name">Heffingskorting</field>
            <field name="code">SR_HK</field>
            <field name="sequence">55</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# Heffingskorting — positief bedrag (credit op loonbelasting)
aftrek_bv = contract._sr_resolve_regels('aftrek_belastingvrij')
result = float_round(payslip._sr_artikel14_hk(categories['GROSS'], aftrek_bv=aftrek_bv), precision_digits=2)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             60 — SR_AOV: AOV Bijdrage werknemer
             ─────────────────────────────────────────────────────────
             4% over het belastbaar loon per periode minus de franchise
             van SRD 400/maand (omgerekend per periode).
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_aov" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">AOV Bijdrage</field>
            <field name="code">SR_AOV</field>
            <field name="sequence">60</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# AOV berekening — ook gecorrigeerd voor aftrek belastingvrij (Art. 10f)
aftrek_bv = contract._sr_resolve_regels('aftrek_belastingvrij')
result = -float_round(payslip._sr_artikel14_aov(categories['GROSS'], aftrek_bv=aftrek_bv), precision_digits=2)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             65 — SR_AFTREK_BV: Aftrek belastingvrij (Art. 10f)
             ─────────────────────────────────────────────────────────
             Pensioenpremie en andere Art. 10f inhoudingen.
             Vermindert LB+AOV grondslag (via calculator parameter)
             én wordt ingehouden op nettoloon (via DED categorie).
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_aftrek_bv" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">Aftrek Belastingvrij (Art. 10f — Pensioenpremie)</field>
            <field name="code">SR_AFTREK_BV</field>
            <field name="sequence">65</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = contract._sr_resolve_regels('aftrek_belastingvrij') > 0
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = -contract._sr_resolve_regels('aftrek_belastingvrij')
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             70 — SR_PENSIOEN: Vaste inhoudingen (contract.sr_vaste_regels)
             Som van alle vaste regels met categorie 'inhouding'.
             (pensioenpremie, ziektekostenpremie, en overige inhoudingen)
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_pensioen" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">Vaste Inhoudingen (Contract)</field>
            <field name="code">SR_PENSIOEN</field>
            <field name="sequence">70</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = contract._sr_resolve_regels('inhouding') > 0
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = -contract._sr_resolve_regels('inhouding')
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             80 — SR_KINDBIJ: Vrijgestelde vergoedingen EXCL. kinderbijslag
             Som van alle vaste regels met categorie 'vrijgesteld' die
             GEEN kinderbijslag type (KINDBIJ) zijn.
             Telt NIET mee in GROSS → geen Art. 14 loonbelasting.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_kinderbijslag" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="name">Vaste Vrijgestelde Vergoedingen (Contract)</field>
            <field name="code">SR_KINDBIJ</field>
            <field name="sequence">80</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
# Vrijgestelde regels excl. kinderbijslag (KB wordt apart afgehandeld)
result = any(
    r.sr_categorie == 'vrijgesteld'
    and (not r.type_id or r.type_id.code != 'KINDBIJ')
    for r in contract.sr_vaste_regels
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = sum(
    contract._sr_resolve_line_amount(r) for r in contract.sr_vaste_regels
    if r.sr_categorie == 'vrijgesteld'
    and (not r.type_id or r.type_id.code != 'KINDBIJ')
)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             81 — SR_KB_VRIJ: Kinderbijslag vrijgesteld deel (Art. 10h)
             Het deel van de kinderbijslag binnen de vrijstelling:
             max SRD 125/kind/maand, max SRD 500/maand.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_kb_vrijgesteld" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="name">Kinderbijslag Vrijgesteld (Art. 10h)</field>
            <field name="code">SR_KB_VRIJ</field>
            <field name="sequence">81</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
max_kind = payslip._rule_parameter('SR_KINDBIJ_MAX_KIND_MAAND')
max_maand = payslip._rule_parameter('SR_KINDBIJ_MAX_MAAND')
kb = contract._sr_kinderbijslag_split(max_kind, max_maand)
result = kb['vrijgesteld'] > 0
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
max_kind = payslip._rule_parameter('SR_KINDBIJ_MAX_KIND_MAAND')
max_maand = payslip._rule_parameter('SR_KINDBIJ_MAX_MAAND')
kb = contract._sr_kinderbijslag_split(max_kind, max_maand)
result = kb['vrijgesteld']
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             100 — NET: Nettoloon
             BASIC + ALW (bruto + toelagen + kinderbijslag) + DED
             (loonbelasting + AOV + pensioen zijn negatief)
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_net" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.NET"/>
            <field name="name">Netto Loon</field>
            <field name="code">NET</field>
            <field name="sequence">100</field>
            <field name="appears_on_employee_cost_dashboard">True</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = categories['BASIC'] + categories['ALW'] + categories['DED']
            </field>
        </record>

        <!-- ═══════════════════════════════════════════════════════════════
             FLEXIBELE PAYSLIP INPUTS — Belastbaar (seq 23)
             Aggregeert alle 'belastbaar' input types die op de loonstrook
             zijn toegevoegd. Telt mee in GROSS → Art. 14 LB.
             ═══════════════════════════════════════════════════════════════ -->

        <!-- ─────────────────────────────────────────────────────────
             23 — SR_INPUT_BELASTB: Belastbare invoer (payslip inputs)
             Som van alle invoerregels met sr_categorie = 'belastbaar'.
             Telt mee in GROSS → Art. 14 loonbelasting.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_input_belastbaar" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="name">Belastbare Toelagen (Payslip)</field>
            <field name="code">SR_INPUT_BELASTB</field>
            <field name="sequence">23</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = any(
    inp.input_type_id.sr_categorie == 'belastbaar' and inp.amount > 0
    for inp in payslip.input_line_ids
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = sum(
    inp.amount for inp in payslip.input_line_ids
    if inp.input_type_id.sr_categorie == 'belastbaar'
)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             73 — SR_INPUT_AFTREK: Inhoudingen (payslip inputs)
             Som van alle invoerregels met sr_categorie = 'inhouding'.
             Negatief — wordt ingehouden op het nettoloon.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_input_aftrek" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">Overige Inhoudingen (Payslip)</field>
            <field name="code">SR_INPUT_AFTREK</field>
            <field name="sequence">73</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = any(
    inp.input_type_id.sr_categorie == 'inhouding' and inp.amount > 0
    for inp in payslip.input_line_ids
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = -sum(
    inp.amount for inp in payslip.input_line_ids
    if inp.input_type_id.sr_categorie == 'inhouding'
)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             82 — SR_INPUT_VRIJ: Vrijgestelde toelagen (payslip inputs)
             Som vrijgestelde inputs. Na GROSS → niet in Art. 14.
             Telt wel mee in het nettoloon (Art. 10 WLB vergoedingen).
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_input_vrijgesteld" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="name">Vrijgestelde Vergoedingen (Payslip)</field>
            <field name="code">SR_INPUT_VRIJ</field>
            <field name="sequence">82</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = any(
    inp.input_type_id.sr_categorie == 'vrijgesteld' and inp.amount > 0
    for inp in payslip.input_line_ids
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = sum(
    inp.amount for inp in payslip.input_line_ids
    if inp.input_type_id.sr_categorie == 'vrijgesteld'
)
            </field>
        </record>

        <!-- ═══════════════════════════════════════════════════════════════
             OVERWERK — Art. 17c WLB (seq 84–86)
             Overwerk is belastbar maar met eigen schijven (5%/15%/25%).
             Na GROSS → telt NIET mee in Art. 14 grondslag.
             Eigen LB via SR_LB_OVERWERK. AOV: 4% zonder franchise.
             ═══════════════════════════════════════════════════════════════ -->

        <!-- ─────────────────────────────────────────────────────────
             84 — SR_OVERWERK: Overwerk bruto (payslip inputs)
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_overwerk" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="name">Overwerk</field>
            <field name="code">SR_OVERWERK</field>
            <field name="sequence">84</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = any(
    inp.input_type_id.sr_categorie == 'overwerk' and inp.amount > 0
    for inp in payslip.input_line_ids
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = sum(
    inp.amount for inp in payslip.input_line_ids
    if inp.input_type_id.sr_categorie == 'overwerk'
)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             85 — SR_LB_OVERWERK: Loonbelasting Overwerk (Art. 17c)
             Eigen schijven: 5% / 15% / 25% op bruto overwerk.
             Tariefgrenzen worden gelezen uit hr.rule.parameter zodat
             ze bij wetswijziging aanpasbaar zijn via het dashboard.
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_lb_overwerk" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">Loonbelasting Overwerk (Art. 17c)</field>
            <field name="code">SR_LB_OVERWERK</field>
            <field name="sequence">85</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = any(
    inp.input_type_id.sr_categorie == 'overwerk' and inp.amount > 0
    for inp in payslip.input_line_ids
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
bruto_overwerk = sum(
    inp.amount for inp in payslip.input_line_ids
    if inp.input_type_id.sr_categorie == 'overwerk'
)

if bruto_overwerk &lt;= 0:
    result = 0.0
else:
    s1 = payslip._rule_parameter('SR_OWK_SCHIJF_1_GRENS')
    s2 = payslip._rule_parameter('SR_OWK_SCHIJF_2_GRENS')
    r1 = payslip._rule_parameter('SR_OWK_TARIEF_1')
    r2 = payslip._rule_parameter('SR_OWK_TARIEF_2')
    r3 = payslip._rule_parameter('SR_OWK_TARIEF_3')

    if bruto_overwerk &lt;= s1:
        lb = bruto_overwerk * r1
    elif bruto_overwerk &lt;= s2:
        lb = s1 * r1 + (bruto_overwerk - s1) * r2
    else:
        lb = s1 * r1 + (s2 - s1) * r2 + (bruto_overwerk - s2) * r3

    result = -float_round(lb, precision_digits=2)
            </field>
        </record>

        <!-- ─────────────────────────────────────────────────────────
             86 — SR_AOV_OVERWERK: AOV over overwerk
             4% over het bruto overwerkbedrag (geen franchise).
             ───────────────────────────────────────────────────────── -->
        <record id="sr_rule_aov_overwerk" model="hr.salary.rule">
            <field name="struct_id" ref="l10n_sr_hr_payroll.sr_payroll_structure"/>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">AOV Overwerk</field>
            <field name="code">SR_AOV_OVERWERK</field>
            <field name="sequence">86</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = any(
    inp.input_type_id.sr_categorie == 'overwerk' and inp.amount > 0
    for inp in payslip.input_line_ids
)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
bruto_overwerk = sum(
    inp.amount for inp in payslip.input_line_ids
    if inp.input_type_id.sr_categorie == 'overwerk'
)
aov_tarief = payslip._rule_parameter('SR_AOV_TARIEF')
result = -float_round(bruto_overwerk * aov_tarief, precision_digits=2)
            </field>
        </record>

        <!-- ═══════════════════════════════════════════════════════════════
             BIJZONDERE BELONINGEN — Bruto regels (seq 87–89)
             Na GROSS → tellen NIET mee in Art. 14 grondslag.
             LB berekend via Art. 17 marginaal tarief methode.
             ═══════════════════════════════════════════════════════════════ -->

