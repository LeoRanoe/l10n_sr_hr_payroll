bedrag = sum(
    inp.amount for inp in payslip.input_line_ids
    if inp.input_type_id.sr_categorie == 'uitkering_ineens' and inp.amount > 0
)
result = -float_round(bedrag * aov_tarief, precision_digits=2)
            </field>
        </record>

