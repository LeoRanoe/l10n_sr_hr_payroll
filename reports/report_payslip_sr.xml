<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════
         Suriname Loonstrook — Artikel 14 Wet Loonbelasting
         Volledig aangepast QWeb PDF-rapport met transparante berekening.
         Toont alle tussenliggende stappen per Art. 12 / 13 / 14 WLB.
         ═══════════════════════════════════════════════════════════════ -->

    <record id="action_report_payslip_sr" model="ir.actions.report">
        <field name="name">Loonstrook (Artikel 14 WLB)</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_sr_hr_payroll.report_payslip_sr</field>
        <field name="print_report_name">
            'Loonstrook - %s - %s' % (object.employee_id.name, object.date_from.strftime('%B %Y') if object.date_from else '')
        </field>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <!-- Koppel het rapport aan de Suriname salarisstructuur -->
    <record id="l10n_sr_hr_payroll.sr_payroll_structure" model="hr.payroll.structure">
        <field name="report_id" ref="action_report_payslip_sr"/>
    </record>

    <!-- HTML preview actie — toont dezelfde template als inline HTML in de browser -->
    <record id="action_report_payslip_sr_preview" model="ir.actions.report">
        <field name="name">Loonstrook Preview (HTML)</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">l10n_sr_hr_payroll.report_payslip_sr</field>
        <field name="print_report_name">
            'Loonstrook Preview - %s - %s' % (object.employee_id.name, object.date_from.strftime('%B %Y') if object.date_from else '')
        </field>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         QWeb-template — transparante Artikel 14 loonstrook
         Berekening stappen:
           1. Bruto loon (basisloon + toelagen + kinderbijslag)
           2. Annualiseren → forfaitaire aftrek (Art. 12) → belastingvrij (Art. 13)
           3. Belastbaar jaarloon → tariefschijven (Art. 14)
           4. LB per periode = LB jaar ÷ periodes
           5. AOV: grondslag − franchise × 4%
           6. Samenvatting: bruto − inhoudingen = nettoloon
         ═══════════════════════════════════════════════════════════════ -->
    <template id="report_payslip_sr">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="bd" t-value="doc._get_sr_artikel14_breakdown()"/>
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- ── DOCUMENT TITLE ─────────────────────────────────── -->
                    <div class="row mb-3">
                        <div class="col">
                            <h2 class="mt-0 mb-0">LOONSTROOK</h2>
                            <p class="text-muted mb-0">
                                Wet Loonbelasting Suriname &#183;
                                <t t-if="bd.get('is_fn')">Fortnight Loon (26&#215;/jaar)</t>
                                <t t-else="">Maandloon (12&#215;/jaar)</t>
                            </p>
                        </div>
                    </div>

                    <!-- ── WERKNEMER GEGEVENS ────────────────────────────── -->
                    <table class="table table-sm table-bordered mb-3">
                        <thead class="thead-light">
                            <tr>
                                <th colspan="4" class="text-uppercase" style="font-size:8pt;">Werknemer Gegevens</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted" style="width:18%;font-size:8pt;">Werknemer</td>
                                <td class="fw-bold" style="width:32%;">
                                    <t t-esc="doc.employee_id.name"/>
                                </td>
                                <td class="text-muted" style="width:18%;font-size:8pt;">Periode</td>
                                <td class="fw-bold" style="width:32%;">
                                    <t t-esc="doc.date_from.strftime('%d-%m-%Y') if doc.date_from else ''"/>
                                    t/m
                                    <t t-esc="doc.date_to.strftime('%d-%m-%Y') if doc.date_to else ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted" style="font-size:8pt;">Afdeling</td>
                                <td><t t-esc="doc.employee_id.department_id.name or '-'"/></td>
                                <td class="text-muted" style="font-size:8pt;">Referentie</td>
                                <td><t t-esc="doc.number or '-'"/></td>
                            </tr>
                            <tr>
                                <td class="text-muted" style="font-size:8pt;">Functie</td>
                                <td><t t-esc="doc.employee_id.job_id.name or '-'"/></td>
                                <td class="text-muted" style="font-size:8pt;">Loonstructuur</td>
                                <td><t t-esc="doc.struct_id.name or '-'"/></td>
                            </tr>
                            <t t-if="bd.get('fn_period_label')">
                                <tr>
                                    <td class="text-muted" style="font-size:8pt;">FN Tijdvak</td>
                                    <td><t t-esc="bd.get('fn_period_label')"/></td>
                                    <td class="text-muted" style="font-size:8pt;">Indicator</td>
                                    <td><t t-esc="bd.get('fn_period_indicator')"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- ── BRUTO LOON ──────────────────────────────────── -->
                    <table class="table table-sm table-bordered mb-2">
                        <thead>
                            <tr class="table-secondary">
                                <th colspan="2" class="text-uppercase" style="font-size:8pt;">Bruto Loon</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="width:75%;">Basisloon</td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('basic', 0))"/></td>
                            </tr>
                            <t t-if="bd.get('toelagen', 0) != 0">
                                <tr>
                                    <td>Toelagen (belastbaar)</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('toelagen', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('kb_vrijgesteld', 0) != 0">
                                <tr>
                                    <td>
                                        Kinderbijslag (vrijgesteld)
                                        <span class="text-success" style="font-size:7.5pt;">&#9658; belastingvrij (Art. 10h)</span>
                                    </td>
                                    <td class="text-end text-success"><t t-esc="'SRD {:,.2f}'.format(bd.get('kb_vrijgesteld', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('kb_belastbaar', 0) != 0">
                                <tr>
                                    <td>
                                        Kinderbijslag (belastbaar)
                                        <span class="text-danger" style="font-size:7.5pt;">&#9658; belast</span>
                                    </td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('kb_belastbaar', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('vrijgesteld_contract', 0) != 0">
                                <tr>
                                    <td>
                                        Vrijgestelde Vergoedingen (Contract)
                                        <span class="text-success" style="font-size:7.5pt;">&#9658; belastingvrij</span>
                                    </td>
                                    <td class="text-end text-success"><t t-esc="'SRD {:,.2f}'.format(bd.get('vrijgesteld_contract', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('overwerk', 0) != 0">
                                <tr>
                                    <td>Overwerk</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('overwerk', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('vakantie', 0) != 0">
                                <tr>
                                    <td>Vakantiegeld</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('vakantie', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('gratificatie', 0) != 0">
                                <tr>
                                    <td>Gratificatie</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('gratificatie', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('bijz_beloning', 0) != 0">
                                <tr>
                                    <td>Bijzondere Beloning</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('bijz_beloning', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('uitkering_ineens', 0) != 0">
                                <tr>
                                    <td>Uitkering Ineens</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('uitkering_ineens', 0))"/></td>
                                </tr>
                            </t>
                            <tr class="fw-bold table-light">
                                <td>Totaal Bruto Loon</td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('bruto_totaal', 0))"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- ── ARTIKEL 14 WLB BEREKENING ──────────────────── -->
                    <table class="table table-sm table-bordered mb-2">
                        <thead>
                            <tr class="table-secondary">
                                <th colspan="2" class="text-uppercase" style="font-size:8pt;">Loonbelasting Berekening &#8212; Artikel 14 WLB</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="width:75%;">
                                    Bruto belastbaar loon per jaar
                                    <span class="text-muted" style="font-size:8pt;">
                                        (<t t-esc="bd.get('periodes', 12)"/> periodes &#215;
                                        <t t-esc="'SRD {:,.2f}'.format(bd.get('bruto_per_periode', 0))"/>)
                                    </span>
                                </td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('bruto_jaarloon', 0))"/></td>
                            </tr>
                            <tr class="text-muted">
                                <td>&#8722; Belastingvrije som (Art. 13)</td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('belastingvrij_jaar', 0))"/></td>
                            </tr>
                            <tr class="text-muted">
                                <td>
                                    &#8722; Forfaitaire beroepskosten (Art. 12) &#8212;
                                    <t t-esc="'{:.0f}'.format(bd.get('forfaitaire_pct', 4))"/>%,
                                    max SRD <t t-esc="'{:,.0f}'.format(bd.get('forfaitaire_max_jaar', 4800))"/>/jaar
                                </td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('forfaitaire_jaar', 0))"/></td>
                            </tr>
                            <tr class="fw-bold table-light">
                                <td>= Belastbaar Jaarloon</td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('belastbaar_jaarloon', 0))"/></td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-muted fst-italic" style="font-size:7.5pt;">
                                    Tariefschijven Artikel 14 &#8212; Progressief belastingtarief
                                </td>
                            </tr>
                            <t t-foreach="bd.get('tax_brackets', [])" t-as="bracket">
                                <t t-if="bracket.get('basis', 0) > 0">
                                    <tr>
                                        <td style="padding-left:20px;">
                                            Schijf <t t-esc="bracket.get('index')"/> &#8212;
                                            <t t-if="bracket.get('upper') is None">
                                                boven <t t-esc="'SRD {:,.0f}'.format(bracket.get('lower', 0))"/>
                                            </t>
                                            <t t-elif="bracket.get('lower', 0) &lt;= 0">
                                                0 t/m <t t-esc="'SRD {:,.0f}'.format(bracket.get('upper', 0))"/>
                                            </t>
                                            <t t-else="">
                                                <t t-esc="'SRD {:,.0f}'.format(bracket.get('lower', 0))"/> t/m
                                                <t t-esc="'SRD {:,.0f}'.format(bracket.get('upper', 0))"/>
                                            </t>
                                            &#215; <t t-esc="'{:.0f}'.format(bracket.get('rate', 0) * 100)"/>%
                                            <span class="text-muted" style="font-size:7.5pt;">
                                                (<t t-esc="'SRD {:,.2f}'.format(bracket.get('basis', 0))"/> belastbaar)
                                            </span>
                                        </td>
                                        <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bracket.get('tax', 0))"/></td>
                                    </tr>
                                </t>
                            </t>
                            <tr>
                                <td>Loonbelasting per jaar</td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('lb_jaar', 0))"/></td>
                            </tr>
                            <tr class="fw-bold text-danger">
                                <td>Loonbelasting per periode (&#247; <t t-esc="bd.get('periodes', 12)"/>)</td>
                                <td class="text-end">&#8722; <t t-esc="'SRD {:,.2f}'.format(bd.get('lb_per_periode', 0))"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- ── AOV BEREKENING ──────────────────────────────── -->
                    <table class="table table-sm table-bordered mb-2">
                        <thead>
                            <tr class="table-secondary">
                                <th colspan="2" class="text-uppercase" style="font-size:8pt;">AOV Berekening (Algemene Ouderdomsvoorziening)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="width:75%;">Bruto loon per periode</td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('bruto_per_periode', 0))"/></td>
                            </tr>
                            <t t-if="not bd.get('is_fn')">
                                <tr class="text-muted">
                                    <td>&#8722; Franchise (maandloon)</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('franchise_periode', 0))"/></td>
                                </tr>
                            </t>
                            <t t-else="">
                                <tr>
                                    <td class="text-muted fst-italic">Geen franchise (fortnight loon)</td>
                                    <td class="text-end text-muted">&#8212;</td>
                                </tr>
                            </t>
                            <tr>
                                <td>AOV grondslag</td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('aov_grondslag', 0))"/></td>
                            </tr>
                            <tr class="fw-bold text-danger">
                                <td>AOV (<t t-esc="'{:.0f}'.format(bd.get('aov_tarief_pct', 4))"/>%)</td>
                                <td class="text-end">&#8722; <t t-esc="'SRD {:,.2f}'.format(bd.get('aov_per_periode', 0))"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- ── NETTO LOON SAMENVATTING ─────────────────────── -->
                    <table class="table table-sm table-bordered mt-3">
                        <thead>
                            <tr class="table-secondary">
                                <th colspan="2" class="text-uppercase" style="font-size:8pt;">Samenvatting</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="width:70%;">Totaal Bruto Loon</td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('bruto_totaal', 0))"/></td>
                            </tr>
                            <tr class="text-danger">
                                <td>&#8722; Loonbelasting (Art. 14 WLB)</td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('lb_per_periode', 0))"/></td>
                            </tr>
                            <t t-if="bd.get('lb_bijz', 0) > 0">
                                <tr class="text-danger">
                                    <td>&#8722; LB Bijzondere Beloningen (Art. 17)</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('lb_bijz', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('lb_17a', 0) > 0">
                                <tr class="text-danger">
                                    <td>&#8722; LB Uitkering Ineens (Art. 17a)</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('lb_17a', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('lb_overwerk', 0) > 0">
                                <tr class="text-danger">
                                    <td>&#8722; LB Overwerk (Art. 17c)</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('lb_overwerk', 0))"/></td>
                                </tr>
                            </t>
                            <tr class="text-danger">
                                <td>&#8722; AOV (<t t-esc="'{:.0f}'.format(bd.get('aov_tarief_pct', 4))"/>%)</td>
                                <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('aov_per_periode', 0))"/></td>
                            </tr>
                            <t t-if="bd.get('aov_bijz', 0) > 0">
                                <tr class="text-danger">
                                    <td>&#8722; AOV Bijzondere Beloningen</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('aov_bijz', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('aov_17a', 0) > 0">
                                <tr class="text-danger">
                                    <td>&#8722; AOV Uitkering Ineens</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('aov_17a', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('aov_overwerk', 0) > 0">
                                <tr class="text-danger">
                                    <td>&#8722; AOV Overwerk</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('aov_overwerk', 0))"/></td>
                                </tr>
                            </t>
                            <t t-foreach="bd.get('contract_inhoudingen', [])" t-as="inhouding">
                                <tr class="text-danger">
                                    <td>&#8722; <t t-esc="inhouding.get('name')"/></td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(inhouding.get('amount', 0))"/></td>
                                </tr>
                            </t>
                            <t t-foreach="bd.get('input_inhoudingen', [])" t-as="inhouding_input">
                                <tr class="text-danger">
                                    <td>&#8722; <t t-esc="inhouding_input.get('name')"/> (Payslip)</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(inhouding_input.get('amount', 0))"/></td>
                                </tr>
                            </t>
                            <t t-if="bd.get('aftrek_bv', 0) > 0">
                                <tr class="text-danger">
                                    <td>&#8722; Aftrek Bedrijfsvoorheffing</td>
                                    <td class="text-end"><t t-esc="'SRD {:,.2f}'.format(bd.get('aftrek_bv', 0))"/></td>
                                </tr>
                            </t>
                            <tr class="fw-bold table-dark">
                                <td style="font-size:11pt;">NETTO LOON</td>
                                <td class="text-end" style="font-size:11pt;"><t t-esc="'SRD {:,.2f}'.format(bd.get('netto', 0))"/></td>
                            </tr>
                        </tbody>
                    </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
