<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_payslip_sr_shared_styles">
        <style>
            .o_sr_payslip {
                color: #1f2937;
                font-size: 10.5pt;
            }
            .o_sr_payslip__hero {
                display: table;
                width: 100%;
                margin-bottom: 16px;
                border: 1px solid #dbe4ec;
                border-left: 5px solid #0891b2;
                border-radius: 6px;
                background: #f8fafc;
            }
            .o_sr_payslip__hero-left,
            .o_sr_payslip__hero-right {
                display: table-cell;
                vertical-align: top;
                padding: 14px 16px;
            }
            .o_sr_payslip__hero-right {
                width: 28%;
                text-align: right;
                background: #ffffff;
                border-left: 1px solid #e2e8f0;
            }
            .o_sr_payslip__eyebrow {
                font-size: 8.5pt;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: #0f766e;
                font-weight: 700;
            }
            .o_sr_payslip__title {
                margin: 4px 0 0;
                font-size: 18pt;
                font-weight: 700;
                color: #0f172a;
            }
            .o_sr_payslip__subtitle {
                margin-top: 6px;
                font-size: 10pt;
                color: #64748b;
            }
            .o_sr_payslip__hero-label {
                font-size: 8.5pt;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: #64748b;
            }
            .o_sr_payslip__hero-value {
                margin-top: 6px;
                font-size: 13pt;
                font-weight: 700;
                color: #0f172a;
            }
            .o_sr_summary_table {
                width: 100%;
                border-collapse: separate;
                border-spacing: 12px 0;
                margin: 0 0 18px -12px;
            }
            .o_sr_summary_card {
                border: 1px solid #dbe4ec;
                border-radius: 8px;
                background: #ffffff;
                padding: 12px 14px;
                min-height: 64px;
            }
            .o_sr_summary_card_label {
                font-size: 8.5pt;
                text-transform: uppercase;
                color: #64748b;
                letter-spacing: 0.05em;
            }
            .o_sr_summary_card_value {
                margin-top: 6px;
                font-size: 14pt;
                font-weight: 700;
                color: #0f766e;
            }
            .o_sr_panel {
                margin-bottom: 16px;
                padding: 14px 16px;
                border: 1px solid #e2e8f0;
                border-radius: 8px;
                background: #ffffff;
            }
            .o_sr_panel_title {
                margin: 0 0 10px;
                font-size: 9pt;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: #475569;
                font-weight: 700;
            }
            .o_sr_meta {
                width: 100%;
                border-collapse: collapse;
            }
            .o_sr_meta td {
                padding: 4px 0;
            }
            .o_sr_table {
                width: 100%;
                border-collapse: collapse;
                font-size: 10.5pt;
            }
            .o_sr_table thead th {
                padding: 6px 8px;
                background: #e2e8f0;
                border-bottom: 1px solid #cbd5e1;
                color: #0f172a;
                font-weight: 700;
            }
            .o_sr_table tbody td {
                padding: 6px 8px;
                border-bottom: 1px solid #e2e8f0;
            }
            .o_sr_total_row td {
                padding: 8px;
                font-weight: 700;
                background: #f8fafc;
                border-top: 1px solid #cbd5e1;
            }
            .o_sr_text_center {
                text-align: center;
            }
            .o_sr_text_end {
                text-align: right;
            }
            .o_sr_muted {
                color: #64748b;
            }
            .o_sr_net_total {
                margin-top: 18px;
                padding: 12px 16px;
                border: 1px solid #0f172a;
                border-radius: 8px;
                background: #0f172a;
                text-align: right;
            }
            .o_sr_net_total_label {
                font-size: 9pt;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: #cbd5e1;
                margin-right: 12px;
            }
            .o_sr_net_total_value {
                font-size: 18pt;
                font-weight: 700;
                color: #ffffff;
            }
        </style>
    </template>

    <template id="report_payslip_sr_employee_simple">
        <t t-call="web.external_layout">
            <div class="page o_sr_payslip">
                <t t-call="l10n_sr_hr_payroll.report_payslip_sr_shared_styles"/>

                <div class="o_sr_payslip__hero">
                    <div class="o_sr_payslip__hero-left">
                        <div class="o_sr_payslip__eyebrow">Suriname Payroll</div>
                        <h2 class="o_sr_payslip__title">Loonstrook <t t-esc="bd.get('period_title') or ''"/></h2>
                        <div class="o_sr_payslip__subtitle">
                            <t t-esc="doc.employee_id.name or '-'"/> · <t t-esc="doc.company_id.name or '-'"/>
                        </div>
                    </div>
                    <div class="o_sr_payslip__hero-right">
                        <div class="o_sr_payslip__hero-label">Referentie</div>
                        <div class="o_sr_payslip__hero-value"><t t-esc="doc.number or doc.name or '-'"/></div>
                    </div>
                </div>

                <table class="o_sr_summary_table">
                    <tbody>
                        <tr>
                            <td t-foreach="bd.get('summary_cards', [])" t-as="card" style="width:33.33%; vertical-align:top;">
                                <div class="o_sr_summary_card">
                                    <div class="o_sr_summary_card_label">
                                        <t t-esc="card.get('label')"/>
                                    </div>
                                    <div class="o_sr_summary_card_value">
                                        <t t-esc="'SRD {:,.2f}'.format(card.get('amount', 0))"/>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="o_sr_panel">
                    <div class="o_sr_panel_title">Werknemer en contract</div>
                    <table class="o_sr_meta">
                        <tbody>
                        <tr>
                            <td style="width:19%; padding:3px 0;">Afdeling</td>
                            <td style="width:3%; padding:3px 0;">:</td>
                            <td style="width:78%; padding:3px 0;"><t t-esc="doc.employee_id.department_id.name or '-'"/></td>
                        </tr>
                        <tr>
                            <td style="padding:3px 0;">Reg.nr./ Naam</td>
                            <td style="padding:3px 0;">:</td>
                            <td style="padding:3px 0;"><t t-esc="'%s - %s' % (bd.get('employee_reference') or '-', doc.employee_id.name or '-')"/></td>
                        </tr>
                        <tr>
                            <td style="padding:3px 0;">Functie</td>
                            <td style="padding:3px 0;">:</td>
                            <td style="padding:3px 0;"><t t-esc="doc.employee_id.job_id.name or '-'"/></td>
                        </tr>
                        <tr>
                            <td style="padding:3px 0;">Uurloon</td>
                            <td style="padding:3px 0;">:</td>
                            <td style="padding:3px 0;"><t t-esc="'{:,.2f}'.format(bd.get('hourly_wage', 0))"/></td>
                        </tr>
                        <tr>
                            <td style="padding:3px 0;">Datum in dienst</td>
                            <td style="padding:3px 0;">:</td>
                            <td style="padding:3px 0;"><t t-esc="bd.get('employment_start_date').strftime('%d-%b-%Y') if bd.get('employment_start_date') else '-'"/></td>
                        </tr>
                        <tr>
                            <td style="padding:3px 0;">Bankrekeningnr.</td>
                            <td style="padding:3px 0;">:</td>
                            <td style="padding:3px 0;">
                                <t t-esc="bd.get('bank_account_number') or '-'"/>
                                <t t-if="bd.get('bank_name')"> <t t-esc="bd.get('bank_name')"/></t>
                            </td>
                        </tr>
                        </tbody>
                    </table>
                </div>

                <table class="o_sr_table">
                    <thead>
                        <tr>
                            <th style="text-align:left; width:42%;">Omschrijving</th>
                            <th class="o_sr_text_center" style="width:12%;">Aantal</th>
                            <th class="o_sr_text_end" style="width:15%;">Debet</th>
                            <th class="o_sr_text_end" style="width:15%;">Credit</th>
                            <th class="o_sr_text_end" style="width:16%;">Netto</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="bd.get('payslip_line_rows', [])" t-as="row">
                            <td><t t-esc="row.get('name')"/></td>
                            <td class="o_sr_text_center"><t t-esc="row.get('quantity_display') or ''"/></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(row.get('debit', 0)) if row.get('debit', 0) else ''"/></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(row.get('credit', 0)) if row.get('credit', 0) else ''"/></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(row.get('net', 0)) if row.get('net', 0) else ''"/></td>
                        </tr>
                        <tr class="o_sr_total_row">
                            <td>Totaal</td>
                            <td></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(bd.get('display_debit_total', 0))"/></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(bd.get('display_credit_total', 0))"/></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(bd.get('display_net_total', 0))"/></td>
                        </tr>
                    </tbody>
                </table>

                <div class="o_sr_panel" style="margin-top:18px;">
                    <div class="o_sr_panel_title">Uren specificatie</div>
                    <table class="o_sr_table">
                    <thead>
                        <tr>
                            <th style="text-align:left; width:48%;">Omschrijving</th>
                            <th class="o_sr_text_end" style="width:18%;">Uren</th>
                            <th style="width:34%;">Eenheid</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="bd.get('hours_summary_lines', [])" t-as="line">
                            <td><t t-esc="line.get('label')"/></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(line.get('hours', 0))"/></td>
                            <td class="o_sr_muted">uur</td>
                        </tr>
                        <tr t-if="not bd.get('hours_summary_lines')">
                            <td colspan="3" class="o_sr_muted">Geen urenafwijkingen of overwerk geregistreerd in deze loonperiode.</td>
                        </tr>
                    </tbody>
                    </table>
                </div>

                <div t-if="bd.get('worked_days_rows')" class="o_sr_panel" style="margin-top:14px;">
                    <div class="o_sr_panel_title">Werkdagen en bedragen</div>
                    <table class="o_sr_table" style="font-size:10pt;">
                    <thead>
                        <tr>
                            <th style="text-align:left; width:50%;">Werktijdtype</th>
                            <th class="o_sr_text_end" style="width:16%;">Dagen</th>
                            <th class="o_sr_text_end" style="width:16%;">Uren</th>
                            <th class="o_sr_text_end" style="width:18%;">Bedrag</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="bd.get('worked_days_rows', [])" t-as="row">
                            <td><t t-esc="row.get('name')"/></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(row.get('days', 0)) if row.get('days') else ''"/></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(row.get('hours', 0)) if row.get('hours') else ''"/></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(row.get('amount', 0)) if row.get('amount') else ''"/></td>
                        </tr>
                    </tbody>
                    </table>
                </div>
            </div>
        </t>
    </template>

    <template id="report_payslip_sr_employee_compact">
        <t t-call="web.external_layout">
            <div class="page o_sr_payslip">
                <t t-call="l10n_sr_hr_payroll.report_payslip_sr_shared_styles"/>

                <div class="o_sr_payslip__hero">
                    <div class="o_sr_payslip__hero-left">
                        <div class="o_sr_payslip__eyebrow">Suriname Payroll</div>
                        <h2 class="o_sr_payslip__title">Compacte loonstrook <t t-esc="bd.get('period_title') or ''"/></h2>
                        <div class="o_sr_payslip__subtitle">
                            <t t-esc="doc.employee_id.name or '-'"/> · <t t-esc="doc.company_id.name or '-'"/>
                        </div>
                    </div>
                    <div class="o_sr_payslip__hero-right">
                        <div class="o_sr_payslip__hero-label">Netto indicatie</div>
                        <div class="o_sr_payslip__hero-value"><t t-esc="'SRD {:,.2f}'.format(bd.get('netto', 0))"/></div>
                    </div>
                </div>

                <div class="o_sr_panel">
                    <div class="o_sr_panel_title">Werknemer en contract</div>
                    <table class="o_sr_meta">
                        <tbody>
                        <tr>
                            <td style="width:18%; padding:2px 0; color:#555;">Werknemer</td>
                            <td style="width:2%; padding:2px 0;">:</td>
                            <td style="width:30%; padding:2px 0;"><t t-esc="doc.employee_id.name or '-'"/></td>
                            <td style="width:18%; padding:2px 0; color:#555;">Afdeling</td>
                            <td style="width:2%; padding:2px 0;">:</td>
                            <td style="width:30%; padding:2px 0;"><t t-esc="doc.employee_id.department_id.name or '-'"/></td>
                        </tr>
                        <tr>
                            <td style="padding:2px 0; color:#555;">Personeelsnr.</td>
                            <td style="padding:2px 0;">:</td>
                            <td style="padding:2px 0;"><t t-esc="bd.get('employee_reference') or '-'"/></td>
                            <td style="padding:2px 0; color:#555;">Functie</td>
                            <td style="padding:2px 0;">:</td>
                            <td style="padding:2px 0;"><t t-esc="doc.employee_id.job_id.name or '-'"/></td>
                        </tr>
                        <tr>
                            <td style="padding:2px 0; color:#555;">Bankrekening</td>
                            <td style="padding:2px 0;">:</td>
                            <td style="padding:2px 0;"><t t-esc="bd.get('bank_account_number') or '-'"/></td>
                            <td style="padding:2px 0; color:#555;">Datum in dienst</td>
                            <td style="padding:2px 0;">:</td>
                            <td style="padding:2px 0;"><t t-esc="bd.get('employment_start_date').strftime('%d-%b-%Y') if bd.get('employment_start_date') else '-'"/></td>
                        </tr>
                        </tbody>
                    </table>
                </div>

                <table class="o_sr_summary_table">
                    <tbody>
                        <tr>
                            <td t-foreach="bd.get('summary_cards', [])" t-as="card" style="width:33.33%; vertical-align:top;">
                                <div class="o_sr_summary_card">
                                    <div class="o_sr_summary_card_label">
                                        <t t-esc="card.get('label')"/>
                                    </div>
                                    <div class="o_sr_summary_card_value">
                                        <t t-esc="'SRD {:,.2f}'.format(card.get('amount', 0))"/>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <table style="width:100%; border-collapse:separate; border-spacing:0; font-size:10.5pt;">
                    <tbody>
                        <tr>
                            <td style="width:48%; vertical-align:top; padding-right:12px;">
                                <table class="o_sr_table">
                                    <thead>
                                        <tr>
                                            <th colspan="2" style="text-align:left;">Inkomsten</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="bd.get('earnings_lines', [])" t-as="line">
                                            <td><t t-esc="line.get('name')"/></td>
                                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(line.get('amount', 0))"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                            <td style="width:4%;"></td>
                            <td style="width:48%; vertical-align:top; padding-left:12px;">
                                <table class="o_sr_table">
                                    <thead>
                                        <tr>
                                            <th colspan="2" style="text-align:left;">Inhoudingen</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="bd.get('deductions_lines', [])" t-as="line">
                                            <td><t t-esc="line.get('name')"/></td>
                                            <td class="o_sr_text_end"><t t-esc="'{:,.2f}'.format(line.get('amount', 0))"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="o_sr_net_total">
                    <span class="o_sr_net_total_label">Netto uit te betalen</span>
                    <span class="o_sr_net_total_value"><t t-esc="'SRD {:,.2f}'.format(bd.get('netto', 0))"/></span>
                </div>

                <div class="o_sr_panel" style="margin-top:18px;">
                    <div class="o_sr_panel_title">Uren specificatie</div>
                    <table class="o_sr_table">
                    <thead>
                        <tr>
                            <th style="text-align:left;">Omschrijving</th>
                            <th class="o_sr_text_end">Aantal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="bd.get('hours_summary_lines', [])" t-as="line">
                            <td><t t-esc="line.get('label')"/></td>
                            <td class="o_sr_text_end"><t t-esc="'{:,.2f} uur'.format(line.get('hours', 0))"/></td>
                        </tr>
                        <tr t-if="not bd.get('hours_summary_lines')">
                            <td colspan="2" class="o_sr_muted">Geen afwijkende uren of overwerk in deze periode.</td>
                        </tr>
                    </tbody>
                    </table>
                </div>
            </div>
        </t>
    </template>

    <template id="report_payslip_sr_compact">
        <t t-call="web.external_layout">
            <div class="page">
                <h3 class="mt-0 mb-3" style="text-align:center; font-size:16pt; font-weight:700;">
                    Belasting over periode: <t t-esc="bd.get('period_title') or ''"/>
                </h3>

                <div style="font-size:10.5pt; margin-bottom:8px;">
                    <div><strong>Looncode</strong></div>
                    <div style="margin-top:3px;"><strong>Kostenplaats :</strong> <t t-esc="doc.contract_id.name or 'NVT'"/></div>
                    <div style="margin-top:3px;"><strong>Afdeling :</strong> <t t-esc="doc.employee_id.department_id.name or '-'"/></div>
                    <div style="margin-top:3px; color:#9f1d20; font-weight:700;"><t t-esc="'%s %s' % (bd.get('employee_reference') or '', doc.employee_id.name or '')"/></div>
                </div>

                <table style="width:100%; border-collapse:collapse; font-size:10.5pt;">
                    <thead>
                        <tr style="background:#efefef;">
                            <th style="text-align:left; padding:5px 6px; text-decoration:underline;">Looncode</th>
                            <th style="text-align:right; padding:5px 6px; text-decoration:underline;">Verloond bedrag</th>
                            <th style="text-align:right; padding:5px 6px; text-decoration:underline;">Loonbelasting</th>
                            <th style="text-align:right; padding:5px 6px; text-decoration:underline;">Premie AOV</th>
                            <th style="text-align:right; padding:5px 6px; text-decoration:underline;">Aantal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="bd.get('belasting_line_rows', [])" t-as="row">
                            <td style="padding:4px 6px;"><t t-esc="row.get('name')"/></td>
                            <td style="padding:4px 6px; text-align:right;"><t t-esc="'{:,.2f}'.format(row.get('verloond_bedrag', 0)) if row.get('verloond_bedrag', 0) else ''"/></td>
                            <td style="padding:4px 6px; text-align:right;"><t t-esc="'{:,.2f}'.format(row.get('loonbelasting', 0)) if row.get('loonbelasting', 0) else ''"/></td>
                            <td style="padding:4px 6px; text-align:right;"><t t-esc="'{:,.2f}'.format(row.get('premie_aov', 0)) if row.get('premie_aov', 0) else ''"/></td>
                            <td style="padding:4px 6px; text-align:right;"><t t-esc="row.get('quantity_display') or ''"/></td>
                        </tr>
                        <tr>
                            <td style="padding:8px 6px 4px 6px; border-top:1px solid #000; font-weight:700;">Totaal</td>
                            <td style="padding:8px 6px 4px 6px; border-top:1px solid #000; text-align:right; font-weight:700;"><t t-esc="'{:,.2f}'.format(bd.get('belasting_paid_total', 0))"/></td>
                            <td style="padding:8px 6px 4px 6px; border-top:1px solid #000; text-align:right; font-weight:700;"><t t-esc="'{:,.2f}'.format(bd.get('belasting_tax_total', 0))"/></td>
                            <td style="padding:8px 6px 4px 6px; border-top:1px solid #000; text-align:right; font-weight:700;"><t t-esc="'{:,.2f}'.format(bd.get('belasting_aov_total', 0))"/></td>
                            <td style="padding:8px 6px 4px 6px; border-top:1px solid #000;"></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <template id="report_payslip_sr_detailed">
        <t t-call="web.external_layout">
            <div class="page">

                <div class="row mb-3">
                    <div class="col">
                        <h2 class="mt-0 mb-0">LOONSTROOK</h2>
                        <p class="text-muted mb-0">
                            Wet Loonbelasting Suriname | <t t-esc="bd.get('payslip_layout_label')"/> |
                            <t t-if="bd.get('is_fn')">Fortnight Loon (26x/jaar)</t>
                            <t t-else="">Maandloon (12x/jaar)</t>
                        </p>
                    </div>
                </div>

                <table class="table table-sm table-bordered mb-3">
                    <thead class="thead-light">
                        <tr>
                            <th colspan="4" class="text-uppercase" style="font-size:8pt;">Werknemer Gegevens</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="text-muted" style="width:18%;font-size:8pt;">Werknemer</td>
                            <td class="fw-bold" style="width:32%;"><t t-esc="doc.employee_id.name"/></td>
                            <td class="text-muted" style="width:18%;font-size:8pt;">Periode</td>
                            <td class="fw-bold" style="width:32%;">
                                <t t-esc="doc.date_from.strftime('%d-%m-%Y') if doc.date_from else ''"/>
                                t/m
                                <t t-esc="doc.date_to.strftime('%d-%m-%Y') if doc.date_to else ''"/>
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted" style="font-size:8pt;">Afdeling</td>
                            <td><t t-esc="doc.employee_id.department_id.name or '-'"/></td>
                            <td class="text-muted" style="font-size:8pt;">Referentie</td>
                            <td><t t-esc="doc.number or '-'"/></td>
                        </tr>
                        <tr>
                            <td class="text-muted" style="font-size:8pt;">Functie</td>
                            <td><t t-esc="doc.employee_id.job_id.name or '-'"/></td>
                            <td class="text-muted" style="font-size:8pt;">Loonstructuur</td>
                            <td><t t-esc="doc.struct_id.name or '-'"/></td>
                        </tr>
                        <tr>
                            <td class="text-muted" style="font-size:8pt;">Layout</td>
                            <td><t t-esc="bd.get('payslip_layout_label')"/></td>
                            <td class="text-muted" style="font-size:8pt;">Indicator</td>
                            <td><t t-esc="bd.get('fn_period_indicator') or '-'"/></td>
                        </tr>
                        <tr t-if="bd.get('fn_period_label')">
                            <td class="text-muted" style="font-size:8pt;">FN Tijdvak</td>
