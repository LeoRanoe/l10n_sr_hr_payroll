<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════
         SR Bedrijfs Jaaroverzicht — Jaar PDF
         Model: sr.payroll.company.year.wizard
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Report action -->
    <record id="action_report_sr_company_year_overview" model="ir.actions.report">
        <field name="name">Bedrijfs Jaaroverzicht Loonbelasting</field>
        <field name="model">sr.payroll.company.year.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_sr_hr_payroll.report_sr_company_year_overview</field>
        <field name="report_file">l10n_sr_hr_payroll.report_sr_company_year_overview</field>
        <field name="paperformat_id" ref="l10n_sr_hr_payroll.paperformat_sr_landscape"/>
    </record>

    <!-- ── QWeb Template ──────────────────────────────────────────── -->
    <template id="report_sr_company_year_overview">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="rd" t-value="o._get_company_year_overview_data()"/>
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 8pt;">

                        <!-- ── Rapportheader ──────────────────────────────── -->
                        <div style="text-align: center; margin-bottom: 10px; border-bottom: 2px solid #2c5f8a; padding-bottom: 8px;">
                            <h4 style="margin: 0; color: #2c5f8a; font-size: 13pt; font-weight: bold;">
                                BEDRIJFS JAAROVERZICHT LOONBELASTING
                            </h4>
                            <p style="margin: 4px 0 0 0; font-size: 10pt; font-weight: bold;">
                                Boekjaar: <t t-esc="rd['year']"/>
                            </p>
                            <p style="margin: 2px 0 0 0; font-size: 7.5pt; color: #666;">
                                Gegenereerd op: <t t-esc="str(rd['generated_on'])"/>
                                &#160;&#160;|&#160;&#160;
                                Totaal werknemers: <t t-esc="rd['employee_count']"/>
                                &#160;&#160;|&#160;&#160;
                                Totaal loonstroken: <t t-esc="rd['slip_count']"/>
                            </p>
                        </div>

                        <!-- ── Afdeling-tabellen ──────────────────────────── -->
                        <t t-foreach="rd['dept_groups']" t-as="dept">
                            <table style="width: 100%; border-collapse: collapse; margin-bottom: 8px; font-size: 7.5pt;">
                                <!-- Afdeling-header -->
                                <tr style="background-color: #2c5f8a; color: white;">
                                    <td colspan="12" style="padding: 4px 6px; font-weight: bold; font-size: 8pt;">
                                        Afdeling: <t t-esc="dept['dept_name']"/>
                                        &#160;(<t t-esc="len(dept['employees'])"/> werknemers)
                                    </td>
                                </tr>
                                <!-- Kolomkoppen -->
                                <tr style="background-color: #dce8f5; font-weight: bold; text-align: right;">
                                    <td style="text-align: left; width: 20%; border: 1px solid #aaa; padding: 3px 4px;">Werknemer</td>
                                    <td style="width: 8%; border: 1px solid #aaa; padding: 3px 4px;">Bruto (SRD)</td>
                                    <td style="width: 7%; border: 1px solid #aaa; padding: 3px 4px;">Bijz.Bel.</td>
                                    <td style="width: 7%; border: 1px solid #aaa; padding: 3px 4px;">LB Art.14</td>
                                    <td style="width: 7%; border: 1px solid #aaa; padding: 3px 4px;">LB Art.17</td>
                                    <td style="width: 6%; border: 1px solid #aaa; padding: 3px 4px;">LB 17a</td>
                                    <td style="width: 6%; border: 1px solid #aaa; padding: 3px 4px;">LB 17c</td>
                                    <td style="width: 8%; border: 1px solid #aaa; padding: 3px 4px;">Totaal LB</td>
                                    <td style="width: 7%; border: 1px solid #aaa; padding: 3px 4px;">AOV</td>
                                    <td style="width: 6%; border: 1px solid #aaa; padding: 3px 4px;">Heff.k.</td>
                                    <td style="width: 6%; border: 1px solid #aaa; padding: 3px 4px;">Pensioen</td>
                                    <td style="width: 8%; border: 1px solid #aaa; padding: 3px 4px;">Netto (SRD)</td>
                                </tr>
                                <!-- Werknemersrijen (jaarlijkse totalen) -->
                                <t t-foreach="dept['employees']" t-as="emp">
                                    <tr style="text-align: right;" t-att-style="'background-color: %s;' % ('#f9f9f9' if emp_index % 2 == 0 else '#ffffff')">
                                        <td style="text-align: left; border: 1px solid #ddd; padding: 2px 4px;">
                                            <t t-esc="emp.get('employee_name', '-')"/>
                                            <span style="color: #888; font-size: 6.5pt; display: block;">
                                                <t t-esc="emp.get('slip_count', 0)"/> periodes
                                            </span>
                                        </td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px;"><t t-esc="'{:,.2f}'.format(emp.get('amount_bruto_srd', 0.0))"/></td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px;"><t t-esc="'{:,.2f}'.format(emp.get('amount_bijz_bruto_srd', 0.0))"/></td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px;"><t t-esc="'{:,.2f}'.format(emp.get('amount_lb_art14_srd', 0.0))"/></td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px;"><t t-esc="'{:,.2f}'.format(emp.get('amount_lb_bijz_srd', 0.0))"/></td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px;"><t t-esc="'{:,.2f}'.format(emp.get('amount_lb_17a_srd', 0.0))"/></td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px;"><t t-esc="'{:,.2f}'.format(emp.get('amount_lb_overwerk_srd', 0.0))"/></td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px; font-weight: bold;"><t t-esc="'{:,.2f}'.format(emp.get('amount_lb_srd', 0.0))"/></td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px;"><t t-esc="'{:,.2f}'.format(emp.get('amount_aov_srd', 0.0))"/></td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px;"><t t-esc="'{:,.2f}'.format(emp.get('amount_heffingskorting_srd', 0.0))"/></td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px;"><t t-esc="'{:,.2f}'.format(emp.get('amount_pensioen_srd', 0.0))"/></td>
                                        <td style="border: 1px solid #ddd; padding: 2px 4px; font-weight: bold;"><t t-esc="'{:,.2f}'.format(emp.get('amount_netto_srd', 0.0))"/></td>
                                    </tr>
                                </t>
                                <!-- Afdelingssubtotaal -->
                                <tr style="background-color: #b8d4ee; font-weight: bold; text-align: right;">
                                    <td style="text-align: left; border: 1px solid #aaa; padding: 3px 4px;">
                                        Subtotaal <t t-esc="dept['dept_name']"/>
                                    </td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_bruto_srd', 0.0))"/></td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_bijz_bruto_srd', 0.0))"/></td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_lb_art14_srd', 0.0))"/></td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_lb_bijz_srd', 0.0))"/></td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_lb_17a_srd', 0.0))"/></td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_lb_overwerk_srd', 0.0))"/></td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_lb_srd', 0.0))"/></td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_aov_srd', 0.0))"/></td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_heffingskorting_srd', 0.0))"/></td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_pensioen_srd', 0.0))"/></td>
                                    <td style="border: 1px solid #aaa; padding: 3px 4px;"><t t-esc="'{:,.2f}'.format(dept['totals'].get('amount_netto_srd', 0.0))"/></td>
                                </tr>
                            </table>
                        </t>

                        <!-- ── Totaal Bedrijf ──────────────────────────────── -->
                        <table style="width: 100%; border-collapse: collapse; margin-top: 8px; font-size: 8pt;">
                            <tr style="background-color: #2c5f8a; color: white; font-weight: bold; text-align: right;">
                                <td style="text-align: left; width: 20%; border: 1px solid #1a4a6b; padding: 4px 6px;">
                                    TOTAAL BEDRIJF <t t-esc="rd['year']"/>
                                    (<t t-esc="rd['employee_count']"/> werknemers)
                                </td>
                                <td style="width: 8%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_bruto_srd', 0.0))"/></td>
                                <td style="width: 7%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_bijz_bruto_srd', 0.0))"/></td>
                                <td style="width: 7%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_lb_art14_srd', 0.0))"/></td>
                                <td style="width: 7%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_lb_bijz_srd', 0.0))"/></td>
                                <td style="width: 6%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_lb_17a_srd', 0.0))"/></td>
                                <td style="width: 6%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_lb_overwerk_srd', 0.0))"/></td>
                                <td style="width: 8%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_lb_srd', 0.0))"/></td>
                                <td style="width: 7%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_aov_srd', 0.0))"/></td>
                                <td style="width: 6%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_heffingskorting_srd', 0.0))"/></td>
                                <td style="width: 6%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_pensioen_srd', 0.0))"/></td>
                                <td style="width: 8%; border: 1px solid #1a4a6b; padding: 4px;"><t t-esc="'{:,.2f}'.format(rd['grand_totals'].get('amount_netto_srd', 0.0))"/></td>
                            </tr>
                        </table>

                        <!-- ── Ondertekeningsblok ─────────────────────────── -->
                        <div style="margin-top: 30px; font-size: 8pt;">
                            <p>Aldus opgemaakt te Paramaribo, <t t-esc="str(rd['generated_on'])"/></p>
                        </div>
                        <table style="width: 60%; margin-top: 20px; font-size: 8pt;">
                            <tr>
                                <td style="width: 45%; border-top: 1px solid #000; padding-top: 4px; text-align: center;">
                                    Directeur / Manager
                                </td>
                                <td style="width: 10%;"></td>
                                <td style="width: 45%; border-top: 1px solid #000; padding-top: 4px; text-align: center;">
                                    Hoofd Administratie
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
